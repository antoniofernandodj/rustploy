<style>
.login_wrap   { width: fill; height: fill; align-x: center; align-y: center; background: var(--bg); }
.login_card   { width: fill; max-width: 460; align-x: start; background: var(--surface); border-radius: 16; border-width: 1; border-color: var(--border); padding: 32; spacing: 16; }
.login_head   { width: fill; spacing: 14; align-y: center; }
.login_brand  { width: fill; spacing: 6; align-x: start; }
.field_group  { width: fill; spacing: 6; }
.field_row    { width: fill; }
.login_checks { width: fill; spacing: 8; padding: 4 0; }
.status_row   { spacing: 14; align-y: center; }
.login_title  { size: 30; bold: true; color: #A9C7FF; }
.field_label  { size: 11; bold: true; color: var(--muted); }
.field_label_fill { width: fill; size: 11; bold: true; color: var(--muted); }
.connect_btn  { width: fill; color: var(--spin); padding: 14; text-align: center; border-radius: 6; }
.ok           { color: var(--ok); }
</style>

<container class="login_wrap">
  <column class="login_card">
    <row class="login_head">

      <svg
        src="crates/rustploy-gui/assets/icons/terminal.svg"
        color="#2F81F7"
        width="34"
        height="34"
      />

      <column class="login_brand">
        <text
          class="login_title"
          content="Rustploy"
        />
        <text
          class="subtitle"
          content="Infrastructure management for professional teams"
        />
      </column>
    </row>

    <form name="login" on_submit="connect" spacing="16" width="fill">

      <column class="field_group">

        <row class="field_row">
          <text class="field_label_fill">
            SERVER URL
          </text>
          <text class="field_label">
            ENDPOINT
          </text>
        </row>

        <input
          placeholder="https://rustploy.chiquitos.tech"
          class="field_input"
          form_control="url"
        />

        <text
          if="{erro_url}"
          not_equals=""
          class="err"
          content="{erro_url}"
        />
      </column>

      <column class="field_group">

        <row class="field_row">
          <text class="field_label_fill">
            ACCESS TOKEN
          </text>
          <text class="field_label" content="SECURE" />
        </row>

        <input
          placeholder="token de acesso"
          class="field_input"
          form_control="token"
        />

      </column>

      <column class="login_checks">

        <checkbox
          checked="remember_url"
          on_toggle="toggle_remember_url"
          label="Remember server"
        />
        <checkbox
          checked="remember_token"
          on_toggle="toggle_remember_token"
          label="Remember token"
        />

      </column>

      <button class="connect_btn" on_click="connect" text="Connect" />
    </form>
    <text if="{error}" not_equals="" class="err">
      ⚠ {error}
    </text>

    <rule />

    <row class="status_row">
      <text class="ok" size="10" content="●" />
      <text class="muted" content="{status_line}" />
    </row>
  </column>
</container>
