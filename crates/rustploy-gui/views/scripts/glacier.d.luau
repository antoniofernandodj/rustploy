export type FetchResult = {
    ok: boolean,
    status: number,
    body: string,
    error: string,
}

export type StreamHandle = {
    id: number,
    close: (self: StreamHandle) -> any,
    send: (self: StreamHandle, text: string) -> any,
}

-- Contexto global do motor: chaveâ†’valor string (o motor coage tudo p/ string).
declare ctx: { [string]: string }

-- Valor do on_change/on_toggle/aĂ§Ă£o-com-sufixo (nil quando a aĂ§Ă£o nĂ£o traz valor).
declare value: string?

-- Tamanho atual da janela em px lĂ³gicos (o que tambĂ©m alimenta @media no GSS).
export type Viewport = {
    width: number,
    height: number,
}
declare function viewport(): Viewport

-- HTTP, ou leitura de arquivo local quando a URL comeĂ§a com `file://`
-- (glacier-ui 0.49+): devolve o mesmo FetchResult, com o conteĂºdo no `body`.
declare function fetch(url: string, opts: any?): FetchResult
-- Escrita de arquivo local (glacier-ui 0.49+), contraparte do `fetch("file://â€¦")`.
-- Devolve `true` no sucesso, ou `false, mensagem` na falha.
declare function write_file(path: string, contents: string): (boolean, string?)
declare function sse(url: string, opts: any?): StreamHandle
declare function websocket(url: string, opts: any?): StreamHandle
declare function toast(opts: any): ()
