-- Multi-janela (glacier-ui 0.36+/0.37+): abrir janela, mensagear entre janelas e
-- fechar a prĂ³pria. `on_broadcast(event, payload)` Ă© definido pelo usuĂ¡rio (a
-- janela receptora), nĂ£o injetado â€” por isso nĂ£o Ă© declarado aqui.
declare function open_window(opts: any): ()
