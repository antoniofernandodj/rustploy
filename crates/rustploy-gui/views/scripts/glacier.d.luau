declare function close_window(): ()

-- Anexa texto ao fim do <textarea> ligado a `binding` (chave do `value`), de
-- forma incremental (o motor insere no Content sem recriĂ¡-lo â€” preserva scroll).
declare function append_textarea(binding: string, text: string): ()

declare json: {
    decode: (s: string) -> any,
    encode: (v: any) -> string,
    array: <T>(t: { T }) -> { T },
}

-- PersistĂªncia local em JSON, anĂ¡loga ao `localStorage` do browser: sobrevive a
-- um restart do processo (ao contrĂ¡rio do `ctx`, que Ă© sĂ³ memĂ³ria). `set` grava
-- qualquer valor JSON-serializĂ¡vel (string, nĂºmero, booleano, tabela); `get`
-- devolve o valor guardado ou nil; `remove` apaga a chave. No rustploy grava em
-- `~/.local/share/rustploy/.glacier-storage/app.json` (raiz definida no Rust via
-- `GlacierDaemon::storage_dir`, glacier-ui 0.45+).
declare storage: {
    get: (key: string) -> any,
    set: (key: string, value: any) -> (),
    remove: (key: string) -> (),
}
