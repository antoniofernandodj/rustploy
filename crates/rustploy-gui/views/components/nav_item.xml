<!--
  Props: label, target, action

  Item de navegação da sidebar. Fica em estado "ligado" (`nav_item_on`) quando
  a view atual ({view}) é igual ao `target` deste item; caso contrário, neutro
  (`nav_item`). `equals` é interpolado, então compara {view} com {target}.
-->
<style>
.nav_item_on {
  width: fill;
  color: var(--blue);
  padding: 11 14;
}
</style>

<button
  class="nav_item_on"
  if="{view}"
  equals="{target}"
  on_click="{action}"
  text="{label}"
/>
<button
  class="nav_item"
  else
  on_click="{action}"
  text="{label}"
/>
