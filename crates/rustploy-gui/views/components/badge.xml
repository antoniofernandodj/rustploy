<!-- 
  Variante "badge" da célula de estado (mesmo ponto + rótulo, mas com o
  espaçamento/estilo de crachá — `badge_lbl`). Usada no card de serviço e no
  cabeçalho/aside do detalhe do serviço.
-->
<row class="badge">
  <text
    class="state_dot"
    color="{color}"
  >●</text>
  <text
    class="badge_lbl"
    color="{color}"
  >{label}</text>
</row>
