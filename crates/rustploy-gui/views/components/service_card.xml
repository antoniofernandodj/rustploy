<!-- 
  Props: id, name, port, status_color, status_label, cpu, mem, filler

  Card de serviço da aba "Serviços" de um projeto — o análogo do ProjectCard.
  Mesmo esquema if/else de topo: `filler=1` rende só o slot vazio que preenche
  a fileira do grid; caso contrário, o card real. O crachá de estado reaproveita
  o componente `rp-badge`.
-->
<style>
.card_stats    {
  width: fill;
  spacing: 12;
}

.card_stat     {
  width: fill;
  spacing: 4;
}

.card_stat_num {
  size: 18;
  bold: true;
  color: var(--text-2);
}

.card_actions  {
  width: fill;
  spacing: 8;
}

.card_stop     {
  width: fill;
  color: var(--border);
  padding: 9 10;
  text-align: center;
  border-radius: 10
}

</style>

<column if="{filler}" equals="1" class="card_filler" />
<column else class="card">
  <row class="card_head">
    <text class="card_name">{name}</text>
    <rp-badge color="{status_color}" label="{status_label}" />
  </row>
  <text class="muted">:{port}</text>
  <rule />
  <row class="card_stats">
    <column class="card_stat">
      <text class="label_cap">CPU</text>
      <text class="card_stat_num">{cpu}</text>
    </column>
    <column class="card_stat">
      <text class="label_cap">MEM</text>
      <text class="card_stat_num">{mem}</text>
    </column>
  </row>
  <!-- 
    Ações empilhadas: 3 botões numa linha só transbordam no tamanho mínimo
    de janela (grade de 3 colunas).
  -->
  <button class="card_open" on_click="open_service:{id}" text="Abrir  ›" />
  <row class="card_actions">
    <button class="card_stop" on_click="svc_stop_id:{id}" text="Parar" />
    <button class="card_remove" on_click="stop_delete_service:{id}" text="Remover" />
  </row>
</column>
