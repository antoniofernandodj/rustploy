<!--
  Props: name, description, logo, logo_kind ("svg" | "img" | "none"), action

  Linha do catálogo de templates de aplicação: logo à esquerda (vetor ou
  raster conforme logo_kind), nome + descrição, e o botão "Escolher" à direita.
  Os logos vêm de crates/shared/templates/blueprints/<id>/<arquivo> (ver
  `templates_json` em app/wizard.rs).
-->
<style>
.tpl_row {
  width: fill;
  padding: 12 0;
  align-y: center;
  spacing: 14;
}

.tpl_logo_box {
  width: 34;
  height: 34;
  align-x: center;
  align-y: center;
}

.tpl_logo {
  width: 30;
  height: 30;
}
</style>

<row class="tpl_row">
  <!--
    Caixa quadrada fixa e centralizada: os logos têm proporções diferentes
    (quadrado, largo, estreito), então reservamos sempre o mesmo espaço e
    centralizamos o logo dentro dele — mantém a coluna de texto alinhada.
  -->
  <column class="tpl_logo_box">
    <svg
      class="tpl_logo"
      if="{logo_kind}"
      equals="svg">{logo}</svg>
    <image
      class="tpl_logo"
      if="{logo_kind}"
      equals="img">{logo}</image>
  </column>
  <column class="header_titles">
    <text class="env_key" content="{name}" />
    <!-- 
      Só renderiza a descrição quando existe — uma linha vazia empurraria o
      nome pra cima e o desalinharia do logo (align-y center da linha).
    -->
    <text
      class="muted"
      if="{description}"
      not_equals=""
      content="{description}"
    />
  </column>
  <button
    class="btn_primary"
    on_click="{action}"
    text="Escolher ›"
  />
</row>
