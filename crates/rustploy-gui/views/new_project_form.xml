<!-- Janela "Novo projeto": motor Glacier próprio, aberto por open_window a partir
  do app principal (handlers/projects.luau → open_new_project_window), que semeia
  a conexão (api_url/api_token) via open_window({ data = ... }). Ao concluir,
  o script (scripts/new_project_window.luau) emite broadcast("project_created")
  e chama close_window(). Linka o tema + o app.gss para herdar a mesma aparência
  (cada janela é um motor isolado; o stylesheet não vem "de graça"). -->
<link rel="theme"       href="crates/rustploy-gui/views/styles/theme.json" />
<link rel="stylesheet"  href="crates/rustploy-gui/views/styles/app.gss" />

<style>
.np_wrap    { width: fill; height: fill; background: var(--bg); padding: 24; spacing: 18; }
.np_head    { width: fill; spacing: 5; }
.np_title   { size: 20; bold: true; color: var(--text); }
.np_group   { width: fill; spacing: 6; }
.np_label   { size: 11; bold: true; color: var(--muted); }
.np_input   { width: fill; }
.np_actions { width: fill; spacing: 10; align-y: center; }
.np_spacer  { width: fill; }
</style>

<column class="np_wrap">

  <column class="np_head">
    <text class="np_title">Novo projeto</text>
    <text class="muted">Cadastre um projeto no cluster conectado.</text>
  </column>

  <form name="np_form" on_submit="submit_project" width="fill" spacing="14">

    <column class="np_group">
      <text class="np_label">NOME</text>
      <input
        class="np_input"
        form_control="np_name"
        value="np_name"
        on_change="field:np_name"
        placeholder="Nome do projeto"
      />
    </column>

    <column class="np_group">
      <text class="np_label">DESCRIÇÃO (OPCIONAL)</text>
      <input
        class="np_input"
        form_control="np_desc"
        value="np_desc"
        on_change="field:np_desc"
        placeholder="Descrição"
      />
    </column>

    <text if="{np_err}" not_equals="" class="err">{np_err}</text>
    <text if="{np_msg}" not_equals="" class="muted">{np_msg}</text>

    <row class="np_actions">
      <column class="np_spacer" />
      <button class="btn_ghost"   on_click="cancel"         text="Cancelar" />
      <button class="btn_primary" on_click="submit_project" text="Criar projeto" />
    </row>

  </form>

  <script src="scripts/new_project_window.luau"></script>
</column>
