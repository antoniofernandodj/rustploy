<style>
.col_icon       { width: 28; }
.content_center { width: fill; height: fill; align-x: center; align-y: center; }
</style>

<column class="content">

  <!-- ── Monitoring ───────────────────────────────────────────────────── -->
  <!-- Bloco com múltiplos filhos condicionais: precisa da TAG if, não do
       atributo if= (que só condiciona o próprio elemento). -->
  <if cond="{view}" equals="monitoring">
    <row class="header_row">
      <column class="header_titles">
        <text class="title" content="Monitoring" />
        <text class="subtitle">
          Host and per-container resource usage.
        </text>
      </column>
    </row>
    <row class="stats_row">
      <StatCard label="CPU" value="{sys_cpu}" />
      <StatCard label="MEMORY" value="{sys_mem}" accent="1" />
      <StatCard label="DISK" value="{sys_disk}" />
      <StatCard label="LOAD" value="{sys_load}" />
    </row>
    <column class="panel_fill">
      <row class="thead">
        <text class="th col_svc" content="CONTAINER" />
        <text class="th col_proj" content="PROJETO" />
        <text class="th col_dur" content="CPU" />
        <text class="th col_dur" content="MEM" />
        <text class="th col_dur" content="RX" />
        <text class="th col_start" content="TX" />
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <column class="row_wrap" for-each="monitoring" var="m">
            <row class="trow">
              <text class="td_key col_svc" content="{m.name}" />
              <text class="td col_proj" content="{m.project}" />
              <text class="td col_dur" content="{m.cpu}" />
              <text class="td col_dur" content="{m.mem}" />
              <text class="muted col_dur" content="{m.rx}" />
              <text class="muted col_start" content="{m.tx}" />
            </row>
            <rule />
          </column>
        </column>
      </scrollable>
    </column>
  </if>

  <!-- ── Ingress ──────────────────────────────────────────────────────── -->
  <if cond="{view}" equals="ingress">
    <row class="header_row">
      <column class="header_titles">
        <text class="title" content="Ingress" />
        <text class="subtitle">
          Active routes in the reverse proxy.
        </text>
      </column>
      <row class="stats_row">
        <StatCard label="ROUTES" value="{ingress_count}" />
      </row>
    </row>
    <column class="panel_fill">
      <row class="thead">
        <text class="th col_svc" content="DOMÍNIO" />
        <text class="th col_proj" content="SERVIÇO" />
        <text class="th col_dur" content="UPSTREAM" />
        <text class="th col_start" content="TLS" />
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <foreach items="ingress" var="i">
            <column class="row_wrap">
              <row class="trow">
                <text class="td_key col_svc" content="{i.domain}" />
                <text class="td col_proj" content="{i.service}" />
                <text class="td col_dur" content="{i.upstream}" />
                <text class="muted col_start" content="{i.tls}" />
              </row>
              <rule />
            </column>
          </foreach>
        </column>
      </scrollable>
    </column>
  </if>

  <!-- ── Deploy Engine ────────────────────────────────────────────────── -->
  <!-- KPIs + deploys em andamento + histórico das últimas 24h. Tudo vem do
       Command::DeployEngineStatus (ver eng_* em app/net.rs); sem backend novo. -->
  <if cond="{view}" equals="deploy_engine">
    <row class="header_row">
      <column class="header_titles">
        <text class="title" content="Deploy Engine" />
        <text
          class="subtitle"
          content="Pipeline de deploy: em andamento e histórico recente."
        />
      </column>
      <row class="stats_row">
        <StatCard label="ATIVOS" value="{eng_active_count}" accent="1" />
        <StatCard label="SUCESSO 24H" value="{eng_success_24h}" />
        <StatCard label="FALHAS 24H" value="{eng_failed_24h}" />
        <StatCard label="TOTAL 24H" value="{eng_total_24h}" />
        <StatCard label="UPTIME" value="{eng_uptime}" />
      </row>
    </row>

    <!-- Executando agora -->
    <column class="panel_fill">
      <text class="label_cap">
        EXECUTANDO AGORA ({eng_active_count})
      </text>
      <row class="thead">
        <text class="th col_svc" content="SERVIÇO" />
        <text class="th col_proj" content="PROJETO" />
        <text class="th col_state" content="ESTADO" />
        <text class="th col_dur" content="PROGRESSO" />
        <text class="th col_dur" content="TOTAL" />
        <text class="th col_start" content="FASE" />
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <text
            if="{eng_active_count}"
            equals="0"
            class="muted"
            content="Nenhum deploy em andamento."
          />

          <column class="row_wrap" for-each="eng_active" var="a">
            <row class="trow">
              <text class="td_key col_svc" content="{a.service}" />
              <text class="td col_proj" content="{a.project}" />
              <StateCell kind="{a.state_kind}" label="{a.state_label}" />
              <text class="td col_dur" content="{a.bar} {a.percent}" />
              <text class="muted col_dur" content="{a.total}" />
              <text class="muted col_start" content="{a.phase}" />
            </row>
            <rule />
          </column>

        </column>
      </scrollable>

      <!-- Histórico 24h -->
      <text class="label_cap">
        HISTÓRICO 24H ({eng_recent_count})
      </text>
      <row class="thead">
        <text class="th col_icon" content="" />
        <text class="th col_svc" content="SERVIÇO" />
        <text class="th col_proj" content="PROJETO" />
        <text class="th col_state" content="ESTADO" />
        <text class="th col_dur" content="DURAÇÃO" />
        <text class="th col_start" content="INÍCIO" />
      </row>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <text
            if="{eng_recent_count}"
            equals="0"
            class="muted"
            content="Nenhum deploy concluído nas últimas 24h."
          />
          <column class="row_wrap" for-each="eng_recent" var="r">
            <row class="trow">
              <text class="td col_icon" content="{r.icon}" />
              <text class="td_key col_svc" content="{r.service}" />
              <text class="td col_proj" content="{r.project}" />
              <StateCell kind="{r.state_kind}" label="{r.state_label}" />
              <text class="muted col_dur" content="{r.duration}" />
              <text class="muted col_start" content="{r.start}" />
            </row>
            <rule />
          </column>
        </column>
      </scrollable>
    </column>
  </if>

  <!-- ── Docker ───────────────────────────────────────────────────────── -->
  <!-- Sub-abas Containers / Images / Volumes / Networks. As três últimas
       listam TODO o host Docker (não só recursos geridos pelo Rustploy — ver
       `docker_inventory` no daemon), com indicação de uso e botão de limpar
       as que estão sem uso. -->
  <if cond="{view}" equals="docker">
    <row class="header_row">
      <column class="header_titles">
        <text class="title" content="Docker" />
        <text
          class="subtitle"
          content="Containers, imagens, volumes e networks do host."
        />
      </column>
      <row class="stats_row">
        <StatCard label="IMAGENS" value="{docker_images_count}" />
        <StatCard label="VOLUMES" value="{docker_volumes_count}" />
        <StatCard label="NETWORKS" value="{docker_networks_count}" accent="1" />
      </row>
    </row>

    <row class="tabs">
      <TabButton
        label="Containers"
        current="{docker_tab}"
        target="containers"
        action="docker_tab:containers"
      />
      <TabButton
        label="Images"
        current="{docker_tab}"
        target="images"
        action="docker_tab:images"
      />
      <TabButton
        label="Volumes"
        current="{docker_tab}"
        target="volumes"
        action="docker_tab:volumes"
      />
      <TabButton
        label="Networks"
        current="{docker_tab}"
        target="networks"
        action="docker_tab:networks"
      />
    </row>
    <rule />

    <!-- Containers — um por serviço gerido pelo Rustploy (ligação com
         projeto/serviço é direta, já que o container nasce de um Service). -->
    <column class="panel_fill" if="{docker_tab}" equals="containers">
      <row class="thead">
        <text class="th col_svc" content="SERVIÇO" />
        <text class="th col_proj" content="IMAGEM" />
        <text class="th col_state" content="ESTADO" />
        <text class="th col_start" content="CONTAINER" />
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <foreach items="docker_rows" var="c">
            <column class="row_wrap">
              <row class="trow">
                <text class="td_key col_svc" content="{c.name}" />
                <text class="td col_proj" content="{c.image}" />
                <StateCell kind="{c.status_kind}" label="{c.status_label}" />
                <text class="muted col_start" content="{c.container}" />
              </row>
              <rule />
            </column>
          </foreach>
        </column>
      </scrollable>
    </column>

    <!-- Images — projeto/serviço é melhor esforço (inferido pela tag; imagens
         manuais/de terceiros ficam com "—"). -->
    <column class="panel_fill" if="{docker_tab}" equals="images">
      <row class="env_head">
        <text class="muted_fill">
          {docker_images_count} imagem(ns)
        </text>
        <checkbox
          checked="docker_images_only_used"
          on_toggle="field:docker_images_only_used"
          label="Somente em uso"
        />
        <checkbox
          checked="docker_prune_all_images"
          on_toggle="field:docker_prune_all_images"
          label="-a (limpar tudo, não só dangling)"
        />
        <button
          class="btn_danger"
          on_click="docker_prune_images"
          text="Limpar sem uso"
        />
      </row>
      <text if="{docker_msg}" not_equals="" class="muted">
        {docker_msg}
      </text>
      <row class="thead">
        <text class="th col_svc" content="TAGS" />
        <text class="th col_proj" content="PROJETO / SERVIÇO" />
        <text class="th col_dur" content="TAMANHO" />
        <text class="th col_dur" content="CRIADA" />
        <text class="th col_start" content="USO" />
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <!-- Sub-aba já vem ordenada por tag (docker_images_json); o checkbox
               "Somente em uso" só esconde as linhas SEM USO, sem round-trip. -->
          <if cond="{docker_images_only_used}" equals="true">
            <column
              class="row_wrap"
              for-each="docker_images"
              var="i"
              if="{i.in_use_label}"
              equals="EM USO"
            >
              <row class="trow">
                <text class="td_key col_svc" content="{i.tags}" />
                <text class="td col_proj" content="{i.project} / {i.service}" />
                <text class="muted col_dur" content="{i.size}" />
                <text class="muted col_dur" content="{i.created}" />
                <StateCell kind="{i.in_use_kind}" label="{i.in_use_label}" />
              </row>
              <rule />
            </column>
          </if> <else>
            <column class="row_wrap" for-each="docker_images" var="i">
              <row class="trow">
                <text class="td_key col_svc" content="{i.tags}" />
                <text class="td col_proj" content="{i.project} / {i.service}" />
                <text class="muted col_dur" content="{i.size}" />
                <text class="muted col_dur" content="{i.created}" />
                <StateCell kind="{i.in_use_kind}" label="{i.in_use_label}" />
              </row>
              <rule />
            </column>
          </else>
        </column>
      </scrollable>
    </column>

    <!-- Volumes — Rustploy só usa bind mounts, então volumes nomeados aqui são
         sempre externos ao Rustploy (criados manualmente ou por VOLUME da imagem). -->
    <column class="panel_fill" if="{docker_tab}" equals="volumes">
      <row class="env_head">
        <text
          class="muted_fill"
          content="{docker_volumes_count} volume(s)"
        />
        <checkbox
          checked="docker_volumes_only_used"
          on_toggle="field:docker_volumes_only_used"
          label="Somente em uso"
        />
        <checkbox
          checked="docker_prune_all_volumes"
          on_toggle="field:docker_prune_all_volumes"
          label="-a (limpar tudo, não só anônimos)"
        />
        <button
          class="btn_danger"
          on_click="docker_prune_volumes"
          text="Limpar sem uso"
        />
      </row>
      <text
        if="{docker_msg}"
        not_equals=""
        class="muted"
        content="{docker_msg}"
      />
      <row class="thead">
        <text class="th col_svc" content="NOME" />
        <text class="th col_proj" content="DRIVER" />
        <text class="th col_dur" content="TAMANHO" />
        <text class="th col_start" content="USO" />
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <if cond="{docker_volumes_only_used}" equals="true">
            <foreach items="docker_volumes" var="v">
              <column class="row_wrap" if="{v.in_use_label}" equals="EM USO">
                <row class="trow">
                  <text class="td_key col_svc" content="{v.name}" />
                  <text class="td col_proj" content="{v.driver}" />
                  <text class="muted col_dur" content="{v.size}" />
                  <StateCell kind="{v.in_use_kind}" label="{v.in_use_label}" />
                </row>
                <rule />
              </column>
            </foreach>
          </if> <else>
            <column for-each="docker_volumes" var="v" class="row_wrap">
              <row class="trow">
                <text class="td_key col_svc" content="{v.name}" />
                <text class="td col_proj" content="{v.driver}" />
                <text class="muted col_dur" content="{v.size}" />
                <StateCell kind="{v.in_use_kind}" label="{v.in_use_label}" />
              </row>
              <rule />
            </column>
          </else>
        </column>
      </scrollable>
    </column>

    <!-- Networks — projeto reconhecido pela convenção rp_net_&lt;id curto&gt;. -->
    <column class="panel_fill" if="{docker_tab}" equals="networks">
      <row class="env_head">
        <text class="muted_fill">
          {docker_networks_count} network(s)
        </text>
        <checkbox
          checked="docker_networks_only_used"
          on_toggle="field:docker_networks_only_used"
          label="Somente em uso"
        />
        <button
          class="btn_danger"
          on_click="docker_prune_networks"
          text="Limpar sem uso"
        />
      </row>
      <text if="{docker_msg}" not_equals="" class="muted">
        {docker_msg}
      </text>
      <row class="thead">
        <text class="th col_svc" content="NOME" />
        <text class="th col_proj" content="PROJETO" />
        <text class="th col_dur" content="DRIVER" />
        <text class="th col_dur" content="CONTAINERS" />
        <text class="th col_start" content="USO" />
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <if cond="{docker_networks_only_used}" equals="true">
            <foreach items="docker_networks" var="n">
              <column class="row_wrap" if="{n.in_use_label}" equals="EM USO">
                <row class="trow">
                  <text class="td_key col_svc" content="{n.name}" />
                  <text class="td col_proj" content="{n.project}" />
                  <text class="muted col_dur" content="{n.driver}" />
                  <text class="muted col_dur" content="{n.containers}" />
                  <StateCell kind="{n.in_use_kind}" label="{n.in_use_label}" />
                </row>
                <rule />
              </column>
            </foreach>
          </if> <else>
            <foreach items="docker_networks" var="n">
              <column class="row_wrap">
                <row class="trow">
                  <text class="td_key col_svc" content="{n.name}" />
                  <text class="td col_proj" content="{n.project}" />
                  <text class="muted col_dur" content="{n.driver}" />
                  <text class="muted col_dur" content="{n.containers}" />
                  <StateCell kind="{n.in_use_kind}" label="{n.in_use_label}" />
                </row>
                <rule />
              </column>
            </foreach>
          </else>
        </column>
      </scrollable>
    </column>
  </if>

  <!-- ── Settings: sub-abas Web Server | Git ──────────────────────────── -->
  <if cond="{view}" equals="settings">
    <row class="header_row">
      <column class="header_titles">
        <text
          class="title"
          content="Settings"
        />
        <text
          class="subtitle"
          content="Daemon web server, HTTPS e contas Git."
        />
      </column>
    </row>
    <row class="tabs">
      <TabButton
        label="Web Server"
        current="{settings_tab}"
        target="web"
        action="settings_tab:web"
      />
      <TabButton
        label="Git"
        current="{settings_tab}"
        target="git"
        action="settings_tab:git"
      />
    </row>
    <rule />

    <!-- Web Server (default) -->
    <if cond="{settings_tab}" not_equals="git">
      <form name="settings" on_submit="settings_save" width="fill">
        <column class="form_panel">
          <text class="label_cap" content="DOMÍNIO / URL BASE" />
          <TextInput
            placeholder="https://rustploy.meusite.com"
            class="field_input"
            formControl="ss_domain"
          />

          <text
            class="muted"
            content="Base das URLs de webhook dos serviços e do callback OAuth."
          />
          <text
            class="label_cap"
            content="E-MAIL LET'S ENCRYPT (HTTPS AUTOMÁTICO)"
          />
          <TextInput
            placeholder="voce@exemplo.com"
            class="field_input"
            formControl="ss_email"
          />

          <text
            if="{erro_ss_email}"
            not_equals=""
            class="err"
            content="{erro_ss_email}"
          />
          <text
            class="muted"
            content="Certificados TLS emitidos automaticamente. Requer restart do daemon."
          />

          <row class="env_add">
            <button class="btn_primary" on_click="settings_save" text="Save" />
            <text class="muted" content="{settings_msg}" />
          </row>
        </column>
      </form>
    </if>

    <!-- Git: contas conectadas + formulário de conexão -->
    <if cond="{settings_tab}" equals="git">
      <scrollable direction="vertical" class="scroll_fill">
        <column class="form_panel">
          <text class="label_cap">
            CONTAS CONECTADAS ({gitea_count})
          </text>
          <text
            if="{gitea_count}"
            equals="0"
            class="muted"
            content="Nenhuma conta Gitea conectada ainda."
          />

          <column class="kv_list">
            <foreach items="gitea_providers" var="p">
              <row class="kv_row">
                <column class="header_titles">
                  <text class="env_key" content="{p.name}" />
                  <text
                    class="muted" content="{p.base_url}  ·  {p.auth_mode}  ·  {p.account}"
                  />
                </column>
                <button class="btn_danger" on_click="gp_delete:{p.id}" text="Remover" />
              </row>
            </foreach>
          </column>

          <rule />
          <text class="label_cap" content="CONECTAR CONTA GITEA" />
          <text if="{gp_msg}" not_equals="" class="muted">
            {gp_msg}
          </text>
          <!-- OAuth: o Luau não abre o navegador; guarda a URL em gp_oauth_url e
               o built-in open:<chave> do glacier abre no navegador padrão. -->
          <button
            if="{gp_oauth_url}"
            not_equals=""
            class="btn_primary"
            on_click="open:gp_oauth_url"
            text="Abrir autorização no navegador"
          />

          <form
            name="git_provider"
            on_submit="gp_connect"
            spacing="10"
            width="fill"
          >
            <row class="hc_grid">
              <column class="hc_field">
                <text class="label_cap" content="NOME" />
                <TextInput
                  placeholder="Meu Gitea"
                  class="field_input"
                  formControl="gp_name"
                  value="gp_name"
                  on_change="field:gp_name"
                />
                <text
                  if="{erro_gp_name}"
                  not_equals=""
                  class="err"
                  content="{erro_gp_name}"
                />
              </column>
              <column class="hc_field">
                <text class="label_cap" content="BASE URL" />
                <TextInput
                  placeholder="https://gitea.exemplo.com"
                  class="field_input"
                  formControl="gp_base_url"
                  value="gp_base_url"
                  on_change="field:gp_base_url"
                />
              </column>
            </row>

            <text class="label_cap" content="MÉTODO" />
            <row class="tabs">
              <TabButton
                label="OAuth2"
                current="{gp_mode}"
                target="oauth"
                action="gp_mode:oauth"
              />
              <TabButton
                label="Token (PAT)"
                current="{gp_mode}"
                target="pat"
                action="gp_mode:pat"
              />
            </row>

            <!-- OAuth2 -->
            <if cond="{gp_mode}" not_equals="pat">
              <text class="label_cap" content="CLIENT ID" />
              <TextInput
                placeholder=""
                class="field_input"
                formControl="gp_client_id"
                value="gp_client_id"
                on_change="field:gp_client_id"
              />

              <text class="label_cap" content="CLIENT SECRET" />
              <TextInput
                placeholder=""
                secure="true"
                class="field_input"
                formControl="gp_client_secret"
                value="gp_client_secret"
                on_change="field:gp_client_secret"
              />

              <text
                class="label_cap"
                content="REDIRECT URI (cole no app OAuth do Gitea)"
              />
              <row class="kv_row">
                <text
                  class="kv_val_fill"
                  content="{gp_redirect}"
                />
                <button
                  class="copy_btn"
                  on_click="clipboard:gp_redirect"
                  text="Copiar"
                />
              </row>
              <text
                class="muted"
                content="No Gitea: Settings → Applications → crie um OAuth2 app e cole a Redirect URI acima."
              />
            </if>

            <!-- PAT -->
            <if cond="{gp_mode}" equals="pat">
              <text class="label_cap">
                PERSONAL ACCESS TOKEN
              </text>
              <TextInput
                placeholder=""
                secure="true"
                class="field_input"
                formControl="gp_pat"
                value="gp_pat"
                on_change="field:gp_pat"
              />

              <text
                class="muted"
                content="No Gitea: Settings → Applications → Generate New Token (escopo: repo)."
              />
            </if>

            <row class="env_add">
              <button
                class="btn_primary"
                on_click="gp_connect"
                text="Copiar"
              />
              <button
                class="tab"
                on_click="gp_refresh"
                text="Atualizar lista"
              />
            </row>
          </form>
        </column>
      </scrollable>
    </if>
  </if>

  <!-- ── Schedules / Support (placeholders) ───────────────────────────── -->
  <column class="content_center" if="{view}" equals="schedules">
    <text class="title" content="Schedules" />
    <text
      class="subtitle"
      content="Agendamentos de auto-deploy — em breve."
    />
  </column>
  <column class="content_center" if="{view}" equals="support">
    <text
      class="title"
      content="Support"
    />
    <text
      class="subtitle"
      content="github.com/antoniofernandodj/rustploy"
    />
  </column>

</column>