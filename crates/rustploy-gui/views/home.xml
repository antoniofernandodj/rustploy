<style>
.col_icon       { width: 28; }
.content_center { width: fill; height: fill; align-x: center; align-y: center; }
/* Botão "Remover" compacto por-linha nas sub-abas Docker. */
.dk_rm    { color: var(--danger); padding: 5 12; border-radius: 6; }
.col_act  { width: 120; align-x: end; }
</style>

<column class="content">

  <!-- ── Monitoring ───────────────────────────────────────────────────── -->
  <!-- Bloco com múltiplos filhos condicionais: precisa da TAG if, não do
       atributo if= (que só condiciona o próprio elemento). -->
  <if cond="{view}" equals="monitoring">
    <row class="header_row">
      <column class="header_titles">
        <text class="title">Monitoring</text>
        <text class="subtitle">
          Host and per-container resource usage.
        </text>
      </column>
    </row>
    <row class="stats_row">
      <StatCard label="CPU" value="{sys_cpu}" />
      <StatCard label="MEMORY" value="{sys_mem}" accent="1" />
      <StatCard label="DISK" value="{sys_disk}" />
      <StatCard label="LOAD" value="{sys_load}" />
    </row>
    <column class="panel_fill">
      <row class="thead">
        <text class="th col_svc">CONTAINER</text>
        <text class="th col_proj">PROJETO</text>
        <text class="th col_dur">CPU</text>
        <text class="th col_dur">MEM</text>
        <text class="th col_dur">RX</text>
        <text class="th col_start">TX</text>
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <column class="row_wrap" for-each="monitoring" var="m">
            <row class="trow">
              <text class="td_key col_svc">{m.name}</text>
              <text class="td col_proj">{m.project}</text>
              <text class="td col_dur">{m.cpu}</text>
              <text class="td col_dur">{m.mem}</text>
              <text class="muted col_dur">{m.rx}</text>
              <text class="muted col_start">{m.tx}</text>
            </row>
            <rule />
          </column>
        </column>
      </scrollable>
    </column>
  </if>

  <!-- ── Ingress ──────────────────────────────────────────────────────── -->
  <if cond="{view}" equals="ingress">
    <row class="header_row">
      <column class="header_titles">
        <text class="title">Ingress</text>
        <text class="subtitle">
          Active routes in the reverse proxy.
        </text>
      </column>
      <row class="stats_row">
        <StatCard label="ROUTES" value="{ingress_count}" />
        <StatCard label="PORTAS DE HOST" value="{host_ports_count}" />
      </row>
    </row>
    <column class="panel_fill">
      <row class="thead">
        <text class="th col_svc">DOMÍNIO</text>
        <text class="th col_proj">SERVIÇO</text>
        <text class="th col_dur">UPSTREAM</text>
        <text class="th col_start">TLS</text>
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <foreach items="ingress" var="i">
            <column class="row_wrap">
              <row class="trow">
                <text class="td_key col_svc">{i.domain}</text>
                <text class="td col_proj">{i.service}</text>
                <text class="td col_dur">{i.upstream}</text>
                <text class="muted col_start">{i.tls}</text>
              </row>
              <rule />
            </column>
          </foreach>
        </column>
      </scrollable>

      <!-- Portas TCP de host: exposição direta de porta (fora do proxy HTTP
           por domínio acima) — um serviço pode ter as duas, só uma, ou nenhuma. -->
      <text class="label_cap">
        PORTAS TCP DE HOST ({host_ports_count})
      </text>
      <row class="thead">
        <text class="th col_svc">SERVIÇO</text>
        <text class="th col_proj">PROJETO</text>
        <text class="th col_dur">PORTA HOST</text>
        <text class="th col_start">PORTA CONTAINER</text>
      </row>
      <text if="{host_ports_count}" equals="0" class="muted">
        Nenhum serviço com porta de host configurada.
      </text>
      <column class="table_body">
        <foreach items="host_ports" var="hp">
          <column class="row_wrap">
            <row class="trow">
              <text class="td_key col_svc">{hp.service}</text>
              <text class="td col_proj">{hp.project}</text>
              <text class="td col_dur">{hp.host_port}</text>
              <text class="muted col_start">{hp.container_port}</text>
            </row>
            <rule />
          </column>
        </foreach>
      </column>
    </column>
  </if>

  <!-- ── Deploy Engine ────────────────────────────────────────────────── -->
  <!-- KPIs + deploys em andamento + histórico das últimas 24h. Tudo vem do
       Command::DeployEngineStatus (ver eng_* em app/net.rs); sem backend novo. -->
  <if cond="{view}" equals="deploy_engine">
    <row class="header_row">
      <column class="header_titles">
        <text class="title">Deploy Engine</text>
        <text class="subtitle">
          Pipeline de deploy: em andamento e histórico recente.
        </text>
      </column>
      <row class="stats_row">
        <StatCard label="ATIVOS" value="{eng_active_count}" accent="1" />
        <StatCard label="SUCESSO 24H" value="{eng_success_24h}" />
        <StatCard label="FALHAS 24H" value="{eng_failed_24h}" />
        <StatCard label="TOTAL 24H" value="{eng_total_24h}" />
        <StatCard label="UPTIME" value="{eng_uptime}" />
      </row>
    </row>

    <!-- Executando agora -->
    <column class="panel_fill">
      <text class="label_cap">
        EXECUTANDO AGORA ({eng_active_count})
      </text>
      <row class="thead">
        <text class="th col_svc">SERVIÇO</text>
        <text class="th col_proj">PROJETO</text>
        <text class="th col_state">ESTADO</text>
        <text class="th col_dur">PROGRESSO</text>
        <text class="th col_dur">TOTAL</text>
        <text class="th col_start">FASE</text>
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <text if="{eng_active_count}" equals="0" class="muted">
            Nenhum deploy em andamento.
          </text>

          <column class="row_wrap" for-each="eng_active" var="a">
            <row class="trow">
              <text class="td_key col_svc">{a.service}</text>
              <text class="td col_proj">{a.project}</text>
              <StateCell kind="{a.state_kind}" label="{a.state_label}" />
              <text class="td col_dur">{a.bar} {a.percent}</text>
              <text class="muted col_dur">{a.total}</text>
              <text class="muted col_start">{a.phase}</text>
            </row>
            <rule />
          </column>

        </column>
      </scrollable>

      <!-- Histórico 24h -->
      <text class="label_cap">
        HISTÓRICO 24H ({eng_recent_count})
      </text>
      <row class="thead">
        <text class="th col_icon"></text>
        <text class="th col_svc">SERVIÇO</text>
        <text class="th col_proj">PROJETO</text>
        <text class="th col_state">ESTADO</text>
        <text class="th col_dur">DURAÇÃO</text>
        <text class="th col_start">INÍCIO</text>
      </row>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <text if="{eng_recent_count}" equals="0" class="muted">
            Nenhum deploy concluído nas últimas 24h.
          </text>
          <column class="row_wrap" for-each="eng_recent" var="r">
            <row class="trow">
              <text class="td col_icon">{r.icon}</text>
              <text class="td_key col_svc">{r.service}</text>
              <text class="td col_proj">{r.project}</text>
              <StateCell kind="{r.state_kind}" label="{r.state_label}" />
              <text class="muted col_dur">{r.duration}</text>
              <text class="muted col_start">{r.start}</text>
            </row>
            <rule />
          </column>
        </column>
      </scrollable>
    </column>
  </if>

  <!-- ── Docker ───────────────────────────────────────────────────────── -->
  <!-- Sub-abas Containers / Images / Volumes / Networks. As três últimas
       listam TODO o host Docker (não só recursos geridos pelo Rustploy — ver
       `docker_inventory` no daemon), com indicação de uso e botão de limpar
       as que estão sem uso. -->
  <if cond="{view}" equals="docker">
    <row class="header_row">
      <column class="header_titles">
        <text class="title">Docker</text>
        <text class="subtitle">Containers, imagens, volumes e networks do host.</text>
      </column>
      <row class="stats_row">
        <StatCard label="CONTAINERS" value="{docker_containers_count}" />
        <StatCard label="IMAGENS" value="{docker_images_count}" />
        <StatCard label="VOLUMES" value="{docker_volumes_count}" />
        <StatCard label="NETWORKS" value="{docker_networks_count}" accent="1" />
      </row>
    </row>

    <row class="tabs">
      <TabButton
        label="Containers"
        current="{docker_tab}"
        target="containers"
        action="docker_tab:containers"
      />
      <TabButton
        label="Images"
        current="{docker_tab}"
        target="images"
        action="docker_tab:images"
      />
      <TabButton
        label="Volumes"
        current="{docker_tab}"
        target="volumes"
        action="docker_tab:volumes"
      />
      <TabButton
        label="Networks"
        current="{docker_tab}"
        target="networks"
        action="docker_tab:networks"
      />
    </row>
    <rule />

    <!-- Containers — um por serviço gerido pelo Rustploy (ligação com
         projeto/serviço é direta, já que o container nasce de um Service). -->
    <!-- Containers — todos do host (rodando + parados). Remover é oferecido só
         nos PARADOS (o Docker recusa `rm` de um rodando sem force). -->
    <column class="panel_fill" if="{docker_tab}" equals="containers">
      <row class="env_head">
        <text class="muted_fill">{docker_containers_count} container(s)</text>
        <button
          class="btn_danger"
          on_click="docker_prune_containers"
          text="Limpar parados"
        />
      </row>
      <text if="{docker_msg}" not_equals="" class="muted">{docker_msg}</text>
      <row class="thead">
        <text class="th col_svc">NOME</text>
        <text class="th col_img">IMAGEM</text>
        <text class="th col_state">DONO</text>
        <text class="th col_dur">ESTADO</text>
        <text class="th col_act">AÇÃO</text>
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <column class="row_wrap" for-each="docker_containers" var="c">
            <row class="trow">
              <text class="td_key col_svc">{c.name}</text>
              <text class="td col_img">{c.image}</text>
              <text class="muted col_state">{c.owner}</text>
              <StateCell kind="{c.state_kind}" label="{c.state_label}" />
              <row class="col_act">
                <button
                  if="{c.can_remove}"
                  equals="1"
                  class="dk_rm"
                  on_click="docker_rm_container:{c.id_full}"
                  text="Remover"
                />
              </row>
            </row>
            <rule />
          </column>
        </column>
      </scrollable>
    </column>

    <!-- Images — projeto/serviço é melhor esforço (inferido pela tag; imagens
         manuais/de terceiros ficam com "—"). -->
    <column class="panel_fill" if="{docker_tab}" equals="images">
      <row class="env_head">
        <text class="muted_fill">
          {docker_images_count} imagem(ns)
        </text>
        <checkbox
          checked="docker_images_only_used"
          on_toggle="field:docker_images_only_used"
          label="Somente em uso"
        />
        <checkbox
          checked="docker_prune_all_images"
          on_toggle="field:docker_prune_all_images"
          label="-a (limpar tudo, não só dangling)"
        />
        <button
          class="btn_danger"
          on_click="docker_prune_images"
          text="Limpar sem uso"
        />
      </row>
      <text if="{docker_msg}" not_equals="" class="muted">
        {docker_msg}
      </text>
      <row class="thead">
        <text class="th col_svc">TAGS</text>
        <text class="th col_proj">PROJETO / SERVIÇO</text>
        <text class="th col_dur">TAMANHO</text>
        <text class="th col_dur">CRIADA</text>
        <text class="th col_state">USO</text>
        <text class="th col_act">AÇÃO</text>
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <!-- Sub-aba já vem ordenada por tag (docker_images_json); o checkbox
               "Somente em uso" só esconde as linhas SEM USO, sem round-trip. -->
          <if cond="{docker_images_only_used}" equals="true">
            <column
              class="row_wrap"
              for-each="docker_images"
              var="i"
              if="{i.in_use_label}"
              equals="EM USO"
            >
              <row class="trow">
                <text class="td_key col_svc">{i.tags}</text>
                <text class="td col_proj">{i.project} / {i.service}</text>
                <text class="muted col_dur">{i.size}</text>
                <text class="muted col_dur">{i.created}</text>
                <StateCell kind="{i.in_use_kind}" label="{i.in_use_label}" />
                <row class="col_act">
                  <button
                    if="{i.in_use_label}"
                    equals="SEM USO"
                    class="dk_rm"
                    on_click="docker_rm_image:{i.id_full}"
                    text="Remover"
                  />
                </row>
              </row>
              <rule />
            </column>
          </if> <else>
            <column class="row_wrap" for-each="docker_images" var="i">
              <row class="trow">
                <text class="td_key col_svc">{i.tags}</text>
                <text class="td col_proj">{i.project} / {i.service}</text>
                <text class="muted col_dur">{i.size}</text>
                <text class="muted col_dur">{i.created}</text>
                <StateCell kind="{i.in_use_kind}" label="{i.in_use_label}" />
                <row class="col_act">
                  <button
                    if="{i.in_use_label}"
                    equals="SEM USO"
                    class="dk_rm"
                    on_click="docker_rm_image:{i.id_full}"
                    text="Remover"
                  />
                </row>
              </row>
              <rule />
            </column>
          </else>
        </column>
      </scrollable>
    </column>

    <!-- Volumes — Rustploy só usa bind mounts, então volumes nomeados aqui são
         sempre externos ao Rustploy (criados manualmente ou por VOLUME da imagem). -->
    <column class="panel_fill" if="{docker_tab}" equals="volumes">
      <row class="env_head">
        <text class="muted_fill">{docker_volumes_count} volume(s)</text>
        <checkbox
          checked="docker_volumes_only_used"
          on_toggle="field:docker_volumes_only_used"
          label="Somente em uso"
        />
        <checkbox
          checked="docker_prune_all_volumes"
          on_toggle="field:docker_prune_all_volumes"
          label="-a (limpar tudo, não só anônimos)"
        />
        <button
          class="btn_danger"
          on_click="docker_prune_volumes"
          text="Limpar sem uso"
        />
      </row>
      <text if="{docker_msg}" not_equals="" class="muted">{docker_msg}</text>
      <row class="thead">
        <text class="th col_svc">NOME</text>
        <text class="th col_proj">DRIVER</text>
        <text class="th col_dur">TAMANHO</text>
        <text class="th col_state">USO</text>
        <text class="th col_act">AÇÃO</text>
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <if cond="{docker_volumes_only_used}" equals="true">
            <foreach items="docker_volumes" var="v">
              <column class="row_wrap" if="{v.in_use_label}" equals="EM USO">
                <row class="trow">
                  <text class="td_key col_svc">{v.name}</text>
                  <text class="td col_proj">{v.driver}</text>
                  <text class="muted col_dur">{v.size}</text>
                  <StateCell kind="{v.in_use_kind}" label="{v.in_use_label}" />
                  <row class="col_act" />
                </row>
                <rule />
              </column>
            </foreach>
          </if> <else>
            <column for-each="docker_volumes" var="v" class="row_wrap">
              <row class="trow">
                <text class="td_key col_svc">{v.name}</text>
                <text class="td col_proj">{v.driver}</text>
                <text class="muted col_dur">{v.size}</text>
                <StateCell kind="{v.in_use_kind}" label="{v.in_use_label}" />
                <row class="col_act">
                  <button
                    if="{v.in_use_label}"
                    equals="SEM USO"
                    class="dk_rm"
                    on_click="docker_rm_volume:{v.name}"
                    text="Remover"
                  />
                </row>
              </row>
              <rule />
            </column>
          </else>
        </column>
      </scrollable>
    </column>

    <!-- Networks — projeto reconhecido pela convenção rp_net_&lt;id curto&gt;. -->
    <column class="panel_fill" if="{docker_tab}" equals="networks">
      <row class="env_head">
        <text class="muted_fill">
          {docker_networks_count} network(s)
        </text>
        <checkbox
          checked="docker_networks_only_used"
          on_toggle="field:docker_networks_only_used"
          label="Somente em uso"
        />
        <button
          class="btn_danger"
          on_click="docker_prune_networks"
          text="Limpar sem uso"
        />
      </row>
      <text if="{docker_msg}" not_equals="" class="muted">
        {docker_msg}
      </text>
      <row class="thead">
        <text class="th col_svc">NOME</text>
        <text class="th col_proj">PROJETO</text>
        <text class="th col_dur">DRIVER</text>
        <text class="th col_dur">CONTAINERS</text>
        <text class="th col_state">USO</text>
        <text class="th col_act">AÇÃO</text>
      </row>
      <if cond="{data_loading}" equals="true">
        <LoadingRow />
      </if>
      <scrollable
        if="{data_loading}"
        not_equals="true"
        direction="vertical"
        class="scroll_fill"
      >
        <column class="table_body">
          <if cond="{docker_networks_only_used}" equals="true">
            <foreach items="docker_networks" var="n">
              <column class="row_wrap" if="{n.in_use_label}" equals="EM USO">
                <row class="trow">
                  <text class="td_key col_svc">{n.name}</text>
                  <text class="td col_proj">{n.project}</text>
                  <text class="muted col_dur">{n.driver}</text>
                  <text class="muted col_dur">{n.containers}</text>
                  <StateCell kind="{n.in_use_kind}" label="{n.in_use_label}" />
                  <row class="col_act">
                    <button
                      if="{n.in_use_label}"
                      equals="SEM USO"
                      class="dk_rm"
                      on_click="docker_rm_network:{n.id_full}"
                      text="Remover"
                    />
                  </row>
                </row>
                <rule />
              </column>
            </foreach>
          </if> <else>
            <foreach items="docker_networks" var="n">
              <column class="row_wrap">
                <row class="trow">
                  <text class="td_key col_svc">{n.name}</text>
                  <text class="td col_proj">{n.project}</text>
                  <text class="muted col_dur">{n.driver}</text>
                  <text class="muted col_dur">{n.containers}</text>
                  <StateCell kind="{n.in_use_kind}" label="{n.in_use_label}" />
                  <row class="col_act">
                    <button
                      if="{n.in_use_label}"
                      equals="SEM USO"
                      class="dk_rm"
                      on_click="docker_rm_network:{n.id_full}"
                      text="Remover"
                    />
                  </row>
                </row>
                <rule />
              </column>
            </foreach>
          </else>
        </column>
      </scrollable>
    </column>
  </if>

  <!-- ── Settings: sub-abas Web Server | Git ──────────────────────────── -->
  <if cond="{view}" equals="settings">
    <row class="header_row">
      <column class="header_titles">
        <text class="title">Settings</text>
        <text class="subtitle">Daemon web server, HTTPS e contas Git.</text>
      </column>
    </row>
    <row class="tabs">
      <TabButton
        label="Web Server"
        current="{settings_tab}"
        target="web"
        action="settings_tab:web"
      />
      <TabButton
        label="Git"
        current="{settings_tab}"
        target="git"
        action="settings_tab:git"
      />
      <TabButton
        label="Infra as Code"
        current="{settings_tab}"
        target="iac"
        action="settings_tab:iac"
      />
    </row>
    <rule />

    <!-- Web Server (default) -->
    <if cond="{settings_tab}" equals="web">
      <form name="settings" on_submit="settings_save" width="fill">
        <column class="form_panel">
          <text class="label_cap">DOMÍNIO / URL BASE</text>
          <TextInput
            placeholder="https://rustploy.meusite.com"
            class="field_input"
            formControl="ss_domain"
          />

          <text class="muted">
            Base das URLs de webhook dos serviços e do callback OAuth.
          </text>
          <text class="label_cap">
            E-MAIL LET'S ENCRYPT (HTTPS AUTOMÁTICO)
          </text>
          <TextInput
            placeholder="voce@exemplo.com"
            class="field_input"
            formControl="ss_email"
          />

          <text if="{erro_ss_email}" not_equals="" class="err">
            {erro_ss_email}
          </text>
          <text class="muted">
            Certificados TLS emitidos automaticamente.
            Requer restart do daemon.
          </text>

          <row class="env_add">
            <button class="btn_primary" on_click="settings_save" text="Save" />
            <text class="muted">{settings_msg}</text>
          </row>
        </column>
      </form>
    </if>

    <!-- Git: contas conectadas + formulário de conexão -->
    <if cond="{settings_tab}" equals="git">
      <scrollable direction="vertical" class="scroll_fill">
        <column class="form_panel">
          <text class="label_cap">
            CONTAS CONECTADAS ({gitea_count})
          </text>
          <text if="{gitea_count}" equals="0" class="muted">
            Nenhuma conta Gitea conectada ainda.
          </text>

          <column class="kv_list">
            <foreach items="gitea_providers" var="p">
              <row class="kv_row">
                <column class="header_titles">
                  <text class="env_key">{p.name}</text>
                  <text class="muted">
                    {p.base_url}  ·  {p.auth_mode}  ·  {p.account}
                  </text>
                </column>
                <button class="btn_danger" on_click="gp_delete:{p.id}" text="Remover" />
              </row>
            </foreach>
          </column>

          <rule />
          <text class="label_cap">CONECTAR CONTA GITEA</text>
          <text if="{gp_msg}" not_equals="" class="muted">
            {gp_msg}
          </text>
          <!-- OAuth: o Luau não abre o navegador; guarda a URL em gp_oauth_url e
               o built-in open:<chave> do glacier abre no navegador padrão. -->
          <button
            if="{gp_oauth_url}"
            not_equals=""
            class="btn_primary"
            on_click="open:gp_oauth_url"
            text="Abrir autorização no navegador"
          />

          <form
            name="git_provider"
            on_submit="gp_connect"
            spacing="10"
            width="fill"
          >
            <row class="hc_grid">
              <column class="hc_field">
                <text class="label_cap">NOME</text>
                <TextInput
                  placeholder="Meu Gitea"
                  class="field_input"
                  formControl="gp_name"
                  value="gp_name"
                  on_change="field:gp_name"
                />
                <text if="{erro_gp_name}" not_equals="" class="err">
                  {erro_gp_name}
                </text>
              </column>
              <column class="hc_field">
                <text class="label_cap">BASE URL</text>
                <TextInput
                  placeholder="https://gitea.exemplo.com"
                  class="field_input"
                  formControl="gp_base_url"
                  value="gp_base_url"
                  on_change="field:gp_base_url"
                />
              </column>
            </row>

            <text class="label_cap">MÉTODO</text>
            <row class="tabs">
              <TabButton
                label="OAuth2"
                current="{gp_mode}"
                target="oauth"
                action="gp_mode:oauth"
              />
              <TabButton
                label="Token (PAT)"
                current="{gp_mode}"
                target="pat"
                action="gp_mode:pat"
              />
            </row>

            <!-- OAuth2 -->
            <if cond="{gp_mode}" not_equals="pat">
              <text class="label_cap">CLIENT ID</text>
              <TextInput
                placeholder=""
                class="field_input"
                formControl="gp_client_id"
                value="gp_client_id"
                on_change="field:gp_client_id"
              />

              <text class="label_cap">CLIENT SECRET</text>
              <TextInput
                placeholder=""
                secure="true"
                class="field_input"
                formControl="gp_client_secret"
                value="gp_client_secret"
                on_change="field:gp_client_secret"
              />

              <text class="label_cap">
                REDIRECT URI (cole no app OAuth do Gitea)
              </text>
              <row class="kv_row">
                <text class="kv_val_fill">{gp_redirect}</text>
                <button
                  class="copy_btn"
                  on_click="clipboard:gp_redirect"
                  text="Copiar"
                />
              </row>
              <text class="muted">
                No Gitea: Settings → Applications → crie um OAuth2
                app e cole a Redirect URI acima.
              </text>
            </if>

            <!-- PAT -->
            <if cond="{gp_mode}" equals="pat">
              <text class="label_cap">
                PERSONAL ACCESS TOKEN
              </text>
              <TextInput
                placeholder=""
                secure="true"
                class="field_input"
                formControl="gp_pat"
                value="gp_pat"
                on_change="field:gp_pat"
              />

              <text class="muted">
                No Gitea: Settings → Applications → Generate New Token (escopo: repo).
              </text>
            </if>

            <row class="env_add">
              <button
                class="btn_primary"
                on_click="gp_connect"
                text="Copiar"
              />
              <button
                class="tab"
                on_click="gp_refresh"
                text="Atualizar lista"
              />
            </row>
          </form>
        </column>
      </scrollable>
    </if>

    <!-- Infra as Code: exporta todos os projetos/serviços como YAML (env vars
         sempre redigidas para ${VAR}) + o .env complementar com os valores
         reais; importa colando os dois de volta (cruza e valida faltantes). -->
    <if cond="{settings_tab}" equals="iac">
      <scrollable direction="vertical" class="scroll_fill">
        <column class="form_panel">
          <text class="label_cap">EXPORTAR</text>
          <text class="muted">
            Gera um YAML com todos os projetos e serviços — valores de env var
            nunca aparecem no YAML, só o nome entre cifrão-chaves. Os valores
            reais das vars (exceto secrets, que nunca saem do daemon) vão no
            .env ao lado.
          </text>
          <row class="env_add">
            <button class="btn_primary" on_click="iac_export" text="Exportar tudo" />
            <text class="muted">{iac_export_msg}</text>
          </row>

          <if cond="{iac_has_export}" equals="true">
            <row class="env_head">
              <text class="label_cap">rustploy.yml</text>
              <button class="copy_btn" on_click="clipboard:iac_yaml" text="Copiar" />
            </row>
            <textarea class="env_editor" font="mono" value="iac_yaml" readonly="true" />

            <row class="env_head">
              <text class="label_cap">.env</text>
              <button class="copy_btn" on_click="clipboard:iac_dotenv" text="Copiar" />
            </row>
            <textarea class="env_editor" font="mono" value="iac_dotenv" readonly="true" />
          </if>

          <rule />

          <text class="label_cap">IMPORTAR</text>
          <text class="muted">
            Cole o YAML e o .env correspondente. Falta o valor de alguma
            variável usada no YAML? O import é cancelado antes de aplicar
            qualquer coisa.
          </text>

          <text class="label_cap">rustploy.yml</text>
          <textarea
            class="env_editor"
            font="mono"
            value="iac_import_yaml"
            placeholder="Cole aqui o YAML exportado (ou escrito à mão)"
          />

          <text class="label_cap">.env</text>
          <textarea
            class="env_editor"
            font="mono"
            value="iac_import_dotenv"
            placeholder="Cole aqui o .env com os valores (DB_PASS=s3cr3t)"
          />

          <row class="env_add">
            <checkbox
              checked="iac_prune"
              on_toggle="field:iac_prune"
              label="Remover serviços ausentes do manifesto (prune)"
            />
          </row>
          <row class="env_add">
            <checkbox
              checked="iac_deploy"
              on_toggle="field:iac_deploy"
              label="Disparar deploy dos serviços criados/alterados"
            />
          </row>

          <row class="env_add">
            <button class="btn_primary" on_click="iac_import" text="Importar" />
            <text class="muted">{iac_import_msg}</text>
          </row>

          <if cond="{iac_has_missing}" equals="true">
            <text class="err">
              Variáveis sem valor no .env: {iac_missing_vars}
            </text>
          </if>

          <if cond="{iac_has_report}" equals="true">
            <text class="label_cap">RESULTADO</text>
            <column class="kv_list">
              <row class="kv_row" for-each="iac_report_lines" var="l">
                <text class="muted">{l}</text>
              </row>
            </column>
          </if>
        </column>
      </scrollable>
    </if>
  </if>

  <!-- ── Schedules / Support (placeholders) ───────────────────────────── -->
  <column class="content_center" if="{view}" equals="schedules">
    <text class="title">Schedules</text>
    <text class="subtitle">Agendamentos de auto-deploy — em breve.</text>
  </column>
  <column class="content_center" if="{view}" equals="support">
    <text class="title">Support</text>
    <text class="subtitle">github.com/antoniofernandodj/rustploy</text>
  </column>

</column>