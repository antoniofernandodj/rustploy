<style>
/* Cabeçalho + ações */
.svc_head      { width: fill; align-y: start; }
.svc_title_row { width: fill; spacing: 14; align-y: center; }
.svc_actions   { spacing: 10; align-y: center; }
.btn_blue      { color: var(--blue); padding: 11 22; border-radius: 10 }
/* Corpo: conteúdo da aba + painel lateral */
.svc_body      { width: fill; height: fill; spacing: 20; }
.svc_main      { width: fill; height: fill; spacing: 16; }
.svc_aside     { width: 360; height: fill; spacing: 16; }
.svc_err       { size: 13; color: var(--error); }
/* Connection (pares chave/valor) */
.kv_key        { width: fill; size: 13; color: var(--muted); }
.kv_val        { size: 16; bold: true; color: var(--text); }
/* Environment / General (editores) — .btn_export/.btn_export_on/.env_editor
   agora vivem em app.gss (compartilhados com shell.xml). */
.select        { width: fill; padding: 12 14; background: var(--raised); border-radius: 8; border-width: 1; border-color: #30363D; color: var(--text-2); }
/* Deployments (lista + build log) */
.col_dep_id    { width: 130; }
.col_dep_start { width: fill; }
.dep_image     { size: 11; color: var(--faint); padding: 2 0 0 0; }
.dep_wrap      { width: fill; height: fill; spacing: 8; }
.dep_list_scroll { width: fill; height: 240; }
.dep_actions   { spacing: 8; }
.dep_logs_btn  { color: var(--border); padding: 7 15; border-radius: 6 }
.dep_del_btn   { color: var(--danger); padding: 7 15; border-radius: 6 }
.label_cap_fill { width: fill; size: 11; bold: true; color: var(--faint); }
/* Logs (aba Logs = launcher da janela isolada; painel usado só p/ layout) */
.log_panel     { width: fill; height: fill; background: var(--surface); border-radius: 12; border-width: 1; border-color: var(--border); padding: 14 16; spacing: 8; }
.log_body      { width: fill; spacing: 2; }
.log_line      { width: fill; spacing: 12; }
.log_time      { width: 76; size: 11; color: var(--faint); }
.log_text      { width: fill; size: 12; color: #9DA7B3; }
/* Painel lateral */
.aside_panel   { width: fill; background: var(--surface); border-radius: 12; border-width: 1; border-color: var(--border); padding: 18; spacing: 8; }
.aside_panel_fill { width: fill; height: fill; background: var(--surface); border-radius: 12; border-width: 1; border-color: var(--border); padding: 14 16; spacing: 8; }
/* Responsivo: estreita o painel lateral e aperta o corpo (glacier-ui 0.9.0+). */
@media (max-width: 900) {
  .svc_aside { width: 240; }
  .svc_body  { spacing: 12; }
}
@media (max-width: 560) {
  .svc_aside { width: 170; }
}
</style>

<column class="content">

  <!-- ── Header: nome + estado + ações ────────────────────────────────── -->
  <row class="svc_head">
    <column class="header_titles">
      <row class="svc_title_row">
        <button
          class="btn_ghost"
          on_click="open_project:{svc_project_id}"
          text="‹ {svc_project}"
        />
        <text class="title">{svc_name}</text>
        <rp-badge color="{svc_status_color}" label="{svc_status_label}" />
        <!-- Live "1s, 2s, 3s…" deploy timer: shown only while a deploy started
             from this panel (Deploy/Rebuild) is in flight. Ticked once a second
             by the poll subscription (see `net::poll_stream`'s `sec_tick`), and
             hidden once the deploy finishes — the outcome (success/failure) and
             its total elapsed time then show in `svc_action_msg` below instead. -->
        <row class="badge" if="{svc_deploy_running}" equals="true">
          <text class="state_dot" color="#58A6FF">⏱</text>
          <text class="badge_lbl" color="#58A6FF">{svc_deploy_elapsed}</text>
        </row>
      </row>
      <text if="{svc_action_msg}" not_equals="" class="muted" color="{svc_action_color}">
        {svc_action_msg}
      </text>
    </column>
    <row class="svc_actions">
      <button class="btn_primary" on_click="svc_deploy" text="Deploy" />
      <button class="btn_blue" on_click="svc_reload" text="Reload" />
      <button class="btn_blue" on_click="svc_rebuild" text="Rebuild" />
      <button class="btn_danger" on_click="svc_stop" text="Stop" />
    </row>
  </row>

  <!-- ── Abas ─────────────────────────────────────────────────────────── -->
  <row class="tabs">
    <TabButton
      label="General"
      current="{tab}"
      target="general"
      action="tab:general"
    />
    <TabButton
      label="Connection"
      current="{tab}"
      target="connection"
      action="tab:connection"
    />
    <TabButton
      label="Environment"
      current="{tab}"
      target="environment"
      action="tab:environment"
    />
    <TabButton
      label="Domains"
      current="{tab}"
      target="domains"
      action="tab:domains"
    />
    <TabButton
      label="Deployments"
      current="{tab}"
      target="deployments"
      action="tab:deployments"
    />
    <TabButton
      label="Healthcheck"
      current="{tab}"
      target="healthcheck"
      action="tab:healthcheck"
    />
    <TabButton
      label="Logs"
      current="{tab}"
      target="logs"
      action="tab:logs"
    />
    <TabButton
      label="Advanced"
      current="{tab}"
      target="advanced"
      action="tab:advanced"
    />
  </row>

  <rule />

  <!-- ── Corpo: conteúdo da aba + painel lateral ──────────────────────── -->
  <row class="svc_body">
    <column class="svc_main">
      <text if="{svc_error}" not_equals="" class="svc_err">
        {svc_error}
      </text>

      <!-- General (source / build, editável) -->
      <scrollable if="{tab}" equals="general" direction="vertical" class="scroll_fill">

          <!-- Enquanto o fetch do detalhe (spec + listas conta/repo/branch do
               Gitea) não completa, mostramos um loading — os Selects só aparecem
               depois, já populados, em vez de piscarem vazios. -->
          <column class="form_panel" if="{svc_loading}" equals="true">
            <if cond="{svc_loading}" equals="true">
              <LoadingRow note="Carregando dados do serviço…" />
            </if>
          </column>

          <form
            class="form_panel"
            if="{svc_loading}"
            not_equals="true"
            name="general"
            on_submit="gen_save"
          >

            <!-- Serviços Compose (bancos/brokers) editam o YAML direto; não têm
                 provider Git/Registry. -->
            <if cond="{svc_source_kind}" equals="Compose">
              <text class="label_cap">DOCKER COMPOSE (YAML)</text>
              <text class="muted">
                Edite o compose do serviço.
                Salvar aplica no próximo deploy.
              </text>

              <textarea
                class="env_editor"
                font="mono"
                value="svc_compose"
                placeholder="services:&#10;  app:&#10;    image: …"
              />

              <row class="env_add">
                <button
                  class="btn_primary"
                  on_click="compose_save"
                  text="Salvar compose"
                />
                <button
                  class="btn_ghost"
                  on_click="compose_cancel"
                  text="Cancelar"
                />
                <text class="muted">{svc_action_msg}</text>
              </row>
            </if>

            <!-- Provider Git/Gitea/Registry — apenas para serviços não-Compose. -->
            <if cond="{svc_source_kind}" not_equals="Compose">

            <text class="label_cap">PROVIDER</text>
            <row class="tabs">
              <TabButton
                label="Git"
                current="{prov_tab}"
                target="git"
                action="prov:git"
              />
              <if cond="{gitea_count}" not_equals="0">
                <TabButton
                  label="Gitea"
                  current="{prov_tab}"
                  target="gitea"
                  action="prov:gitea"
                />
              </if>
            </row>
            <rule />

            <!-- ── Sub-aba Git: form de URL/imagem crua ─────────────── -->
            <if cond="{prov_tab}" equals="git">
              <text class="label_cap">
                SOURCE — REPOSITORY URL / IMAGE
              </text>
              <input
                class="field_input"
                form_control="f_repo_url"
                value="f_repo_url"
                on_change="field:f_repo_url"
                placeholder="github.com/user/repo  ou  nginx:latest"
              />

              <text class="muted">
                URL de repositório vira Git;
                caso contrário é imagem de registry.
              </text>
              <row class="hc_grid">
                <column class="hc_field">
                  <text class="label_cap">BRANCH</text>
                  <input
                    class="field_input"
                    form_control="f_branch"
                    value="f_branch"
                    on_change="field:f_branch"
                    placeholder="main"
                  />
                </column>
                <column class="hc_field">
                  <text class="label_cap">PORT</text>
                  <input
                    class="field_input"
                    form_control="f_gen_port"
                    value="f_gen_port"
                    on_change="field:f_gen_port"
                    placeholder="80"
                  />
                  <text if="{erro_f_gen_port}" not_equals="" class="err">
                    {erro_f_gen_port}
                  </text>
                </column>
              </row>
              <row class="hc_grid">
                <column class="hc_field">
                  <text class="label_cap">USERNAME</text>
                  <input
                    class="field_input"
                    form_control="f_username"
                    value="f_username"
                    on_change="field:f_username"
                    placeholder="(opcional)"
                  />
                </column>
                <column class="hc_field">
                  <text class="label_cap">CREDENTIALS (secret)</text>
                  <input
                    class="field_input"
                    form_control="f_credentials"
                    value="f_credentials"
                    on_change="field:f_credentials"
                    placeholder="(opcional)"
                  />
                </column>
              </row>

              <text class="label_cap">BUILD PATH (root)</text>
              <input
                class="field_input"
                form_control="f_build_path"
                value="f_build_path"
                on_change="field:f_build_path"
                placeholder="."
              />

              <text class="label_cap">
                WATCH PATHS (separados por vírgula)
              </text>

              <input
                class="field_input"
                form_control="f_watch_paths"
                value="f_watch_paths"
                on_change="field:f_watch_paths"
                placeholder="src, Cargo.toml"
              />

              <toggle
                checked="f_submodules"
                on_toggle="field:f_submodules"
                label=" Enable submodules" />

              <text class="label_cap">
                BUILD ENGINE: DOCKERFILE
              </text>
              <row class="hc_grid">
                <column class="hc_field">
                  <text class="label_cap">DOCKERFILE</text>
                  <input
                    class="field_input"
                    form_control="f_dockerfile"
                    value="f_dockerfile"
                    on_change="field:f_dockerfile"
                    placeholder="Dockerfile"
                  />
                </column>
                <column class="hc_field">
                  <text class="label_cap">CONTEXT PATH</text>
                  <input
                    class="field_input"
                    form_control="f_context_path"
                    value="f_context_path"
                    on_change="field:f_context_path"
                    placeholder="."
                  />
                </column>
              </row>

              <text class="label_cap">BUILD STAGE (opcional)</text>

              <input
                class="field_input"
                form_control="f_build_stage"
                value="f_build_stage"
                on_change="field:f_build_stage"
                placeholder="(multi-stage target)"
              />

              <row class="env_add">
                <button class="btn_primary" on_click="gen_save" text="Save" />
                <text class="muted">{svc_action_msg}</text>
              </row>
            </if>

            <!-- ── Sub-aba Gitea: picker de conta/repo/branch conectados ─ -->
            <if cond="{prov_tab}" equals="gitea">
              <text class="muted">
                Selecione a conta conectada,
                o repositório e a branch a implantar.
              </text>
              <text if="{gitea_msg}" not_equals="" class="muted">
                {gitea_msg}
              </text>
              <text class="label_cap">CONTA GITEA</text>
              <select
                class="select"
                options="gitea_providers"
                value="gitea_provider_id"
                on_change="gitea_provider_pick"
                placeholder="selecione a conta"
                labelField="display"
                valueField="id"
              />

              <text class="muted">
                Conecte contas em Settings → Git.
              </text>

              <text class="label_cap">REPOSITÓRIO</text>
              <select
                class="select"
                options="gitea_repos"
                value="gitea_repo"
                on_change="gitea_repo_pick"
                placeholder="selecione o repositório"
                labelField="full_name"
                valueField="full_name"
              />

              <text class="label_cap">BRANCH</text>
              <select class="select" options="gitea_branches"
                value="f_branch"
                on_change="field:f_branch"
                placeholder="selecione a branch"
                labelField="name"
                valueField="name"
              />

              <text class="label_cap">SELEÇÃO ATUAL</text>
              <row class="kv_row">
                <text class="kv_key">Repo (clone URL)</text>
                <text class="kv_val_fill">{f_repo_url}</text>
              </row>

              <text class="label_cap">BUILD</text>
              <row class="hc_grid">
                <column class="hc_field">
                  <text class="label_cap">BUILD PATH (root)</text>
                  <input
                    class="field_input"
                    form_control="f_build_path"
                    value="f_build_path"
                    on_change="field:f_build_path"
                    placeholder="."
                  />
                </column>
                <column class="hc_field">
                  <text class="label_cap">PORT</text>
                  <input class="field_input"
                    form_control="f_gen_port"
                    value="f_gen_port"
                    on_change="field:f_gen_port"
                    placeholder="80"
                  />
                  <text if="{erro_f_gen_port}" not_equals="" class="err">
                    {erro_f_gen_port}
                  </text>
                </column>
              </row>
              <row class="hc_grid">
                <column class="hc_field">
                  <text class="label_cap">DOCKERFILE</text>
                  <input
                    class="field_input"
                    form_control="f_dockerfile"
                    value="f_dockerfile"
                    on_change="field:f_dockerfile"
                    placeholder="Dockerfile"
                  />
                </column>
                <column class="hc_field">
                  <text class="label_cap">CONTEXT PATH</text>
                  <input
                    class="field_input"
                    form_control="f_context_path"
                    value="f_context_path"
                    on_change="field:f_context_path"
                    placeholder="."
                  />
                </column>
              </row>
              <text class="label_cap">
                WATCH PATHS (separados por vírgula)
              </text>
              <input
                class="field_input"
                form_control="f_watch_paths"
                value="f_watch_paths"
                on_change="field:f_watch_paths"
                placeholder="src, Cargo.toml"
              />

              <toggle
                checked="f_submodules"
                on_toggle="field:f_submodules"
                label="  Enable submodules"
              />

              <row class="env_add">
                <button class="btn_primary" on_click="gen_save" text="Save" />
                <text class="muted">{svc_action_msg}</text>
              </row>
            </if>
            </if>
          </form>
      </scrollable>

      <!-- Connection (valores copiáveis) -->
      <column if="{tab}" equals="connection" class="kv_list">
        <row class="kv_row">
          <text class="kv_key">Container port</text>
          <text class="kv_val_fill">{svc_port}</text>
          <text>&nbsp;</text>
          <button class="copy_btn" on_click="clipboard:svc_port" text="Copiar" />
        </row>
        <row class="kv_row">
          <text class="kv_key">Host port</text>
          <text class="kv_val_fill">{svc_host_port}</text>
          <text>&nbsp;</text>
          <button class="copy_btn" on_click="clipboard:svc_host_port" text="Copiar" />
        </row>
        <row class="kv_row">
          <text class="kv_key">Domain</text>
          <text class="kv_val_fill">{svc_domain}</text>
          <text>&nbsp;</text>
          <button class="copy_btn" on_click="clipboard:svc_domain" text="Copiar" />
        </row>
        <row class="kv_row">
          <text class="kv_key">TLS</text>
          <text class="kv_val_fill">{svc_tls}</text>
        </row>
        <row class="kv_row">
          <text class="kv_key">External URL</text>
          <text class="kv_val_fill">{svc_external_url_short}</text>
          <text>&nbsp;</text>
          <button class="copy_btn" on_click="clipboard:svc_external_url" text="Copiar" />
        </row>
        <row class="kv_row">
          <text class="kv_key">Internal URL</text>
          <text class="kv_val_fill">{svc_internal_url_short}</text>
          <text>&nbsp;</text>
          <button class="copy_btn" on_click="clipboard:svc_internal_url" text="Copiar" />
        </row>
        <row class="kv_row" if="{svc_db_kind}" not_equals="—">
          <text class="kv_key">Tipo</text>
          <text class="kv_val_fill">{svc_db_kind}</text>
        </row>

        <!-- Containers reais em execução para este serviço (id + nome + estado). -->
        <rule />
        <text class="label_cap">CONTAINERS ({svc_containers_count})</text>
        <text class="muted" if="{svc_containers_count}" equals="0">
          Nenhum container em execução.
        </text>
        <row class="kv_row" for-each="svc_containers" var="c">
          <rp-badge color="{c.state_color}" label="{c.state}" />
          <text class="kv_val_fill">&nbsp;&nbsp;</text>
          <text class="kv_val_fill">{c.name}</text>
          <text class="kv_val_fill">&nbsp;&nbsp;</text>
          <text class="muted">{c.id_short}</text>
        </row>
      </column>

      <!-- Environment -->
      <column if="{tab}" equals="environment" class="env_wrap">
        <row class="env_head">
          <text class="muted_fill">
            {svc_env_count} variável(eis)
          </text>
          <button class="btn_export" on_click="env_export" text="Exportar" />
          <text>&nbsp;</text>
          <if cond="{env_text_open}" equals="true">
            <button class="btn_export_on" on_click="env_text_toggle" text="Fechar" />
          </if>

          <else>
            <button class="tab" on_click="env_text_toggle" text=".env" />
          </else>
        </row>

        <form name="env_add" on_submit="env_add" width="fill">
          <row class="env_add">
            <input
              class="env_in_key"
              form_control="env_new_key"
              placeholder="KEY"
            />

            <input
              class="env_in_val"
              form_control="env_new_val" placeholder="value"
            />

            <button class="btn_primary" on_click="env_add" text="Adicionar" />
          </row>
        </form>
        <text if="{erro_env_new_key}" not_equals="" class="err">
          {erro_env_new_key}
        </text>
        <scrollable direction="vertical" class="env_list_scroll">
          <column class="kv_list">
            <foreach items="svc_env" var="e" on_reorder="env_reorder" reorder_key="key">
              <!-- Comentários (# ...) do .env: arrastáveis como as vars (ao
                   soltar, reancoram na var seguinte da nova ordem), mas sem
                   delete — removem-se editando o .env. A classe da linha muda
                   para `kv_row_drag` no item agarrado ({e.__dragging} vem do
                   glacier-ui durante o arrasto). -->
              <if cond="{e.__dragging}" equals="true">
                <row class="kv_row_drag" if="{e.kind}" equals="comment">
                  <text class="env_drag_handle env_dragging" dragHandle="true">
                    ⋮ 
                  </text>
                  <text class="muted">{e.value}</text>
                </row>
                <row class="kv_row_drag" else>
                  <text class="env_drag_handle env_dragging" dragHandle="true">
                    ⋮ 
                  </text>
                  <button class="env_del" on_click="env_del:{e.key}" text="✕" />
                  <text class="env_sep"> </text>
                  <text class="env_key">{e.key}</text>
                  <text class="kv_val_fill">{e.value}</text>
                </row>
              </if>

              <else>
                <row class="kv_row" if="{e.kind}" equals="comment">
                  <text class="env_drag_handle" dragHandle="true">
                    ⋮ 
                  </text>
                  <text class="muted">{e.value}</text>
                </row>
                <row class="kv_row" else>
                  <text class="env_drag_handle" dragHandle="true">⋮ </text>
                  <button class="env_del" on_click="env_del:{e.key}" text="✕" />
                  <text class="env_sep"> </text>
                  <text class="env_key">{e.key}</text>
                  <text class="kv_val_fill">{e.value}</text>
                </row>
              </else>
            </foreach>
          </column>
        </scrollable>
        <!-- Editor .env: vários filhos condicionais → TAG if (o atributo
             if= só esconderia o Text, deixando TextArea/botões sempre visíveis). -->
        <if cond="{env_text_open}" equals="true">
          <text class="muted">
            Cole/edite no formato KEY=VALUE (# comentário).
          </text>

          <textarea
            class="env_editor"
            font="mono"
            value="svc_env_text"
            placeholder="KEY=VALUE   (# comentário)"
          />

          <row class="env_add">
            <button
              class="btn_primary"
              on_click="env_import"
              text="Salvar"
            />
            <button
              class="btn_ghost"
              on_click="env_text_cancel"
              text="Cancelar"
            />
          </row>
        </if>
      </column>

      <!-- Domains (editável): lista de rotas HTTP (domínio → porta de container,
           TLS por rota), mais o form de adição e a porta TCP crua do host. -->
      <column if="{tab}" equals="domains" class="form_panel">
        <text class="label_cap">
          DOMÍNIOS ({svc_domains_count})
        </text>
        <text class="muted">
         Cada domínio pode apontar para uma porta de container diferente.
        </text>

        <scrollable direction="vertical" class="env_list_scroll">
          <column class="kv_list">
            <row class="kv_row" for-each="svc_domains" var="d">
              <button class="env_del" on_click="dom_del:{d.domain}" text="✕" />
              <text class="env_sep"> </text>
              <text class="env_key">{d.domain}</text>
              <text class="kv_val_fill">→ {d.port}</text>
              <text class="muted">{d.tls_label}</text>
            </row>
          </column>
        </scrollable>

        <text class="label_cap">
          ADICIONAR DOMÍNIO
        </text>
        <input
          class="field_input"
          form_control="f_domain"
          value="f_domain"
          on_change="field:f_domain"
          placeholder="app.exemplo.com"
        />
        <text if="{erro_f_domain}" not_equals="" class="err">
          {erro_f_domain}
        </text>

        <text class="label_cap">
          PORTA DO CONTAINER (opcional)
        </text>
        <input
          class="field_input"
          form_control="f_port"
          value="f_port"
          on_change="field:f_port"
          placeholder="(padrão do serviço)"
        />
        <text if="{erro_f_port}" not_equals="" class="err">
          {erro_f_port}
        </text>

        <toggle checked="f_tls" on_toggle="field:f_tls" label="  HTTPS / TLS" />
        <row class="env_add">
          <button class="btn_primary" on_click="dom_add" text="Adicionar domínio" />
          <text class="muted">
            {svc_action_msg}
          </text>
        </row>

        <text class="label_cap">
          PORTA TCP DO HOST (passthrough, opcional)
        </text>
        <input
          class="field_input"
          form_control="f_host_port"
          value="f_host_port"
          on_change="field:f_host_port"
          placeholder="(padrão do serviço)"
        />
        <text if="{erro_f_host_port}" not_equals="" class="err">
          {erro_f_host_port}
        </text>
        <row class="env_add">
          <button class="btn_ghost"
            on_click="dom_hostport_save"
            text="Salvar porta"
          />
        </row>
      </column>

      <!-- Deployments -->
      <column if="{tab}" equals="deployments" class="dep_wrap">
        <text class="muted">
          {svc_deployments_count} deployments
        </text>
        <scrollable direction="vertical" class="dep_list_scroll">
          <column class="table_body">
            <column class="row_wrap" for-each="svc_deployments" var="d">
              <row class="trow">
                <text class="td_key col_dep_id">{d.id}</text>
                <StateCell kind="{d.state_kind}" label="{d.state_label}" />
                <text class="td col_dur">{d.duration}</text>
                <text class="muted col_dep_start">{d.start}</text>
                <row class="dep_actions">
                  <button
                    class="dep_logs_btn"
                    on_click="dep_logs:{d.id_full}"
                    text="Build log ↗"
                  />
                  <button
                    if="{d.can_delete}"
                    equals="1"
                    class="dep_del_btn"
                    on_click="delete_deployment:{d.id_full}"
                    text="Remover"
                  />
                </row>
              </row>
              <text class="dep_image">
                {d.image}
              </text>
              <rule />
            </column>
          </column>
        </scrollable>
        <!-- Build log abre em JANELA isolada (dep_logs → open_window), não inline:
             render de milhares de linhas por reavaliação travava a principal. -->
      </column>

      <!-- Healthcheck (editável) -->
      <form
        if="{tab}"
        equals="healthcheck"
        class="form_panel"
        name="healthcheck"
        on_submit="hc_save"
      >
        <text class="label_cap">KIND</text>
        <row class="tabs">
          <TabButton
            label="None"
            current="{f_hc_kind}"
            target="none"
            action="hckind:none"
          />
          <TabButton
            label="Tcp"
            current="{f_hc_kind}"
            target="tcp"
            action="hckind:tcp"
          />
          <TabButton
            label="Http"
            current="{f_hc_kind}"
            target="http"
            action="hckind:http"
          />
          <TabButton
            label="Docker"
            current="{f_hc_kind}"
            target="docker"
            action="hckind:docker"
          />
        </row>
        <if cond="{f_hc_kind}" equals="http">
          <text class="label_cap">
            HTTP PATH
          </text>
          <input
            class="field_input"
            form_control="f_hc_path"
            value="f_hc_path"
            on_change="field:f_hc_path"
            placeholder="/health"
          />
          <text class="label_cap">EXPECTED STATUS</text>
          <input
            class="field_input"
            form_control="f_hc_status"
            value="f_hc_status"
            on_change="field:f_hc_status"
            placeholder="200"
          />
          <text if="{erro_f_hc_status}" not_equals="" class="err">
            {erro_f_hc_status}
          </text>
        </if>
        <row class="hc_grid">
          <column class="hc_field">
            <text class="label_cap">
              INTERVAL (s)
            </text>
            <input
              class="field_input"
              form_control="f_hc_interval"
              value="f_hc_interval"
              on_change="field:f_hc_interval"
              placeholder=""
            />
            <text if="{erro_f_hc_interval}" not_equals="" class="err">
              {erro_f_hc_interval}
            </text>
          </column>
          <column class="hc_field">
            <text class="label_cap">
              TIMEOUT (s)
            </text>
            <input
              class="field_input"
              form_control="f_hc_timeout"
              value="f_hc_timeout"
              on_change="field:f_hc_timeout"
              placeholder=""
            />
            <text if="{erro_f_hc_timeout}" not_equals="" class="err">
              {erro_f_hc_timeout}
            </text>
          </column>
        </row>
        <row class="hc_grid">
          <column class="hc_field">
            <text class="label_cap">
              RETRIES
            </text>
            <input
              class="field_input"
              form_control="f_hc_retries"
              value="f_hc_retries"
              on_change="field:f_hc_retries"
              placeholder=""
            />
            <text if="{erro_f_hc_retries}" not_equals="" class="err">
              {erro_f_hc_retries}
            </text>
          </column>
          <column class="hc_field">
            <text class="label_cap">
              START PERIOD (s)
            </text>
            <input
              class="field_input"
              form_control="f_hc_start"
              value="f_hc_start"
              on_change="field:f_hc_start"
              placeholder=""
            />
            <text if="{erro_f_hc_start}" not_equals="" class="err">
              {erro_f_hc_start}
            </text>
          </column>
        </row>
        <row class="env_add">
          <button class="btn_primary" on_click="hc_save" text="Save" />
          <text class="muted">
            {svc_action_msg}
          </text>
        </row>
      </form>

      <!-- Logs de runtime: vivem numa JANELA isolada (motor leve), não inline —
        renderizar o stream aqui reavaliaria a árvore inteira da janela principal
        por linha e a travava. A aba é só o launcher. -->
      <column if="{tab}" equals="logs" class="log_panel">
        <text class="muted">
          Os logs de runtime abrem numa janela própria, isolada do restante do
          app (para não travar a interface sob alto volume de logs).
        </text>
        <row class="env_add">
          <button
            class="btn_primary"
            on_click="open_logs_window"
            text="Abrir logs em janela"
          />
        </row>
      </column>

      <!-- Advanced (editável) -->
      <form
        if="{tab}"
        equals="advanced"
        class="form_panel"
        name="advanced"
        on_submit="adv_save"
      >
        <text class="label_cap">
          REPLICAS
        </text>
        <input
          class="field_input"
          form_control="f_replicas"
          value="f_replicas"
          on_change="field:f_replicas"
          placeholder="1"
        />

        <text if="{erro_f_replicas}" not_equals="" class="err">
          {erro_f_replicas}
        </text>
        <text class="label_cap">
          RUN COMMAND
        </text>
        <input
          class="field_input"
          form_control="f_run_command"
          value="f_run_command"
          on_change="field:f_run_command"
          placeholder="(padrão da imagem)"
        />

        <text class="muted">
          Run args atuais: {svc_run_args}
        </text>

        <row class="env_add">
          <button class="btn_primary" on_click="adv_save" text="Save" />
          <text class="muted">{svc_action_msg}</text>
        </row>
      </form>
    </column>

    <!-- Painel lateral: status. O log ao vivo saiu daqui (era um for-each sempre
      renderizado que a reavaliação processava a cada tick) — agora é janela. -->
    <column class="svc_aside">
      <column class="aside_panel">
        <text class="label_cap">STATUS</text>
        <rp-badge color="{svc_status_color}" label="{svc_status_label}" />
        <text class="label_cap">UPTIME</text>
        <text class="kv_val">{daemon_uptime}</text>
        <text class="label_cap">SERVICES</text>
        <text class="kv_val">{services_label}</text>
      </column>

      <column class="aside_panel_fill">
        <text class="label_cap">LOGS</text>
        <text class="muted">
          Runtime e build logs abrem em janelas próprias (isoladas).
        </text>
        <row class="env_add">
          <button class="tab" on_click="open_logs_window" text="Logs de runtime" />
        </row>
      </column>
    </column>
  </row>
</column>