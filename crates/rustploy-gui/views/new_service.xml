<!--
  Wizard "Novo serviço" (view=new_service): tipo → formulário por tipo,
  espelhando o fluxo do antigo remote-client (Application / Database /
  Compose / Template). O passo corrente vive em {ns_step}; os campos são
  chaves de contexto ns_* (ver os handlers `ns_*` em app/root.rs).
-->
<style>
.warn { color: var(--warn); }
</style>

<Column class="content">

  <Row class="header_row">
    <Column class="header_titles">
      <Text class="title" content="Novo Serviço — {proj_name}" />
      <Text
        class="subtitle"
        content="Escolha o tipo e configure o serviço antes de criar."
      />
    </Column>
    <Row class="env_add">
      <Button class="btn_ghost" on_click="ns_back" text="‹ Voltar" />
      <Button class="btn_ghost" on_click="ns_cancel" text="Cancelar" />
    </Row>
  </Row>

  <Text if="{ns_msg}" not_equals="" class="warn" content="{ns_msg}" />

  <!-- ── Passo 1: tipo de serviço ──────────────────────────────────────── -->
  <if cond="{ns_step}" equals="pick_type">
    <Column class="form_panel">
      <Text class="label_cap" content="ESCOLHA O TIPO DE SERVIÇO" />
      <Column class="kv_list">
        <PickerRow
          title="Application"
          subtitle="Web app via Git ou imagem"
          button_label="Selecionar ›"
          action="ns_kind:application"
        />
        <PickerRow
          title="Database"
          subtitle="Banco de dados gerenciado"
          button_label="Selecionar ›"
          action="ns_kind:database"
        />
        <PickerRow
          title="Broker"
          subtitle="Mensageria: Kafka, RabbitMQ, NATS"
          button_label="Selecionar ›"
          action="ns_kind:broker"
        />
        <PickerRow
          title="Compose"
          subtitle="Stack Docker Compose"
          button_label="Selecionar ›"
          action="ns_kind:compose"
        />
        <PickerRow
          title="Template"
          subtitle="A partir de um preset"
          button_label="Selecionar ›"
          action="ns_kind:template"
        />
      </Column>
    </Column>
  </if>

  <!-- ── Passo 2 (Database): escolha do banco ─────────────────────────── -->
  <if cond="{ns_step}" equals="pick_db">
    <Column class="form_panel">
      <Text class="label_cap" content="ESCOLHA O BANCO DE DADOS" />
      <Column class="kv_list">
        <PickerRow
          for-each="ns_dbs"
          var="d"
          title="{d.label}"
          subtitle="{d.image}"
          button_label="Selecionar ›"
          action="ns_db:{d.id}"
        />
      </Column>
    </Column>
  </if>

  <!-- ── Passo 2 (Broker): escolha do broker ──────────────────────────── -->
  <if cond="{ns_step}" equals="pick_broker">
    <Column class="form_panel">
      <Text class="label_cap" content="ESCOLHA O BROKER" />
      <Column class="kv_list">
        <PickerRow
          for-each="ns_brokers"
          var="b"
          title="{b.label}"
          subtitle="{b.image}"
          button_label="Selecionar ›"
          action="ns_broker:{b.id}" />
      </Column>
    </Column>
  </if>

  <!-- ── Application ───────────────────────────────────────────────────── -->
  <if cond="{ns_step}" equals="app_form">
    <Form name="ns_app" on_submit="ns_create" width="fill">
      <Column class="form_panel">
        <Text class="label_cap" content="NOVA APPLICATION" />
        <Text class="label_cap" content="NOME" />
        <TextInput
          placeholder="minha-app"
          class="field_input"
          form_control="ns_name"
          value="ns_name"
          on_change="field:ns_name"
        />
        <Text
          if="{erro_ns_name}"
          not_equals=""
          class="err"
          content="{erro_ns_name}"
        />
        
        <Text
          class="label_cap"
          content="APP NAME (OPCIONAL — usado no lugar do nome)"
        />
        <TextInput
          placeholder="(opcional)"
          class="field_input"
          form_control="ns_app_name"
          value="ns_app_name"
          on_change="field:ns_app_name"
        />
        
        <Text
          class="muted"
          content="Configure a origem (Git ou imagem) na aba General do serviço depois de criar."
        />
        <Row class="env_add">
          <Button
            class="btn_primary"
            on_click="ns_create"
            text="Criar Application"
          />
          <Text class="muted" content="{ns_msg}" />
        </Row>
      </Column>
    </Form>
  </if>

  <!-- ── Compose ───────────────────────────────────────────────────────── -->
  <if cond="{ns_step}" equals="compose_form">
    <Form name="ns_compose" on_submit="ns_create" width="fill">
      <Column class="form_panel">
        <Text class="label_cap" content="NOVA COMPOSE STACK" />
        <Text class="label_cap" content="NOME" />
        <TextInput
          placeholder="minha-stack"
          class="field_input"
          form_control="ns_name"
          value="ns_name"
          on_change="field:ns_name"
        />
        <Text if="{erro_ns_name}"
          not_equals=""
          class="err"
          content="{erro_ns_name}"
        />
        
        <Text
          class="label_cap"
          content="APP NAME (OPCIONAL — usado no lugar do nome)"
        />
        <TextInput
          placeholder="(opcional)"
          class="field_input"
          form_control="ns_app_name"
          value="ns_app_name" on_change="field:ns_app_name" />
        
        <Text
          class="muted"
          content="Configure o compose file dentro do serviço antes de fazer deploy."
        />
        <Row class="env_add">
          <Button class="btn_primary" on_click="ns_create" text="Criar Compose Stack" />
          <Text class="muted" content="{ns_msg}" />
        </Row>
      </Column>
    </Form>
  </if>

  <!-- ── Database (form do banco escolhido) ────────────────────────────── -->
  <if cond="{ns_step}" equals="db_form">
    <Scrollable direction="vertical" class="scroll_fill">
      <Form name="ns_db" on_submit="ns_create" width="fill">
        <Column class="form_panel">
          <Text class="label_cap" content="NOVA {ns_db_label}" />
          <Text class="label_cap" content="NOME" />
          <TextInput
            placeholder="meu-banco"
            class="field_input"
            form_control="ns_name"
            value="ns_name"
            on_change="field:ns_name"
          />
          <Text if="{erro_ns_name}" not_equals=""
            class="err"
            content="{erro_ns_name}"
            />

          <if cond="{ns_db_has_dbname}" equals="true">
            <Text class="label_cap" content="DATABASE NAME" />
            <TextInput
              placeholder="app"
              class="field_input"
              form_control="ns_db_name"
              value="ns_db_name"
              on_change="field:ns_db_name"
            />
          </if>
          
          <if cond="{ns_db_has_user}" equals="true">
            <Text class="label_cap" content="USER" />
            <TextInput
              placeholder="user"
              class="field_input"
              form_control="ns_db_user"
              value="ns_db_user" 
              on_change="field:ns_db_user" 
            />
          </if>
          
          <Text class="label_cap" content="PASSWORD (gerada — pode trocar)" />
          <TextInput
            placeholder="(vazio = sem senha, só no Redis)"
            class="field_input"
            form_control="ns_db_password"
            value="ns_db_password"
            on_change="field:ns_db_password"
          />
          
          <if cond="{ns_db_has_rootpw}"
            equals="true">
            <Text class="label_cap" content="ROOT PASSWORD (gerada — pode trocar)" />
            <TextInput
              placeholder=""
              class="field_input"
              form_control="ns_db_root_password"
              value="ns_db_root_password"
              on_change="field:ns_db_root_password"
            />
          </if>
          
          <Checkbox
            label="Use Replica Sets"
            if="{ns_db_has_replica}"
            equals="true"
            checked="ns_use_replica"
            on_toggle="field:ns_use_replica"
          />

          <Text class="label_cap" content="DOCKER IMAGE" />
          <Row class="kv_row">
            <Text class="kv_val_fill" content="{ns_image}" />
          </Row>

          <Row class="env_add">
            <Button class="btn_primary" on_click="ns_create" text="Criar {ns_db_label}" />
            <Text class="muted" content="{ns_msg}" />
          </Row>
        </Column>
      </Form>
    </Scrollable>
  </if>

  <!-- ── Template: catálogo ─────────────────────────────────────────────── -->
  <if cond="{ns_step}" equals="pick_template">
    <Column class="env_wrap">
      <Column class="hc_field">
        <Text class="label_cap" content="BUSCAR" />
        <TextInput
          placeholder="buscar templates…"
          class="field_input"
          value="ns_tsearch"
          on_change="ns_tsearch"
        />
      </Column>
      <Scrollable direction="vertical" class="scroll_fill">
        <Column class="kv_list">
          <TemplateRow
            for-each="ns_templates"
            var="t"
            name="{t.name}"
            description="{t.description}"
            logo="{t.logo}"
            logo_kind="{t.logo_kind}"
            action="ns_pick_template:{t.id}"
          />
        </Column>
      </Scrollable>
    </Column>
  </if>

  <!-- ── Template: configuração ─────────────────────────────────────────── -->
  <if cond="{ns_step}" equals="template_form">
    <Scrollable direction="vertical" class="scroll_fill">
      <Form name="ns_template" on_submit="ns_create" width="fill">
        <Column class="form_panel">
          <Text class="label_cap" content="{ns_template_name} — CONFIGURAR" />
          <Text class="label_cap" content="NOME DO SERVIÇO" />
          <TextInput
            placeholder="{ns_template_name}"
            class="field_input"
            form_control="ns_name"
            value="ns_name"
            on_change="field:ns_name"
          />

          <ForEach items="ns_template_vars" var="v">
            <Column class="hc_field">
              <Text class="label_cap" content="{v.label}" />
              <TextInput
                placeholder="{v.placeholder}"
                class="field_input"
                value="ns_tv_{v.idx}"
                on_change="field:ns_tv_{v.idx}"
              />
            </Column>
          </ForEach>

          <Row class="env_add">
            <Button
              class="btn_primary"
              on_click="ns_create"
              text="Criar {ns_template_name}"
            />
            <Text class="muted" content="{ns_msg}" />
          </Row>
        </Column>
      </Form>
    </Scrollable>
  </if>
</Column>
