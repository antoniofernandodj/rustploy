/* ── Rustploy — glacier-ui stylesheet.─────────────────────────────────────
   Terminal-flavoured dark theme, monospaced throughout, matching design/.

   Aqui ficam apenas os seletores COMPARTILHADOS por mais de um template (mais
   alguns utilitários ainda sem uso). Seletores usados por um único template
   moram no <style> desse próprio template — o glacier-ui escopa cada <style>
   à subárvore do componente que o declara, então colocá-los junto do markup
   mantém o estilo perto de quem o usa. */

/* ── Design tokens (glacier-ui 0.8.0+) ─────────────────────────────────────
   Fonte única da paleta. Referenciados via var(--x) aqui e nos <style> dos
   templates (var() é cross-sheet: esta :root global resolve em qualquer sheet
   com escopo). Trocar um tom aqui reflete no app inteiro. */

:root {
    --bg:      #0A0E14;   /* fundo do app */
    --surface: #0D1117;   /* painéis / sidebar / inputs */
    --raised:  #161B22;   /* cards / cabeçalho de tabela / linha arrastada */
    --border:  #21262D;   /* bordas + botões ghost/sutis */
    --text:    #E6EDF3;   /* texto/títulos mais claros */
    --text-2:  #C9D1D9;   /* valores/corpo */
    --muted:   #8B949E;   /* secundário */
    --faint:   #6E7681;   /* rótulos apagados */
    --accent:  #58A6FF;   /* azul de destaque */
    --blue:    #1F6FEB;   /* botões/abas azuis */
    --spin:    #2F81F7;   /* ação (connect) / spinner */
    --green:   #238636;   /* botão primário */
    --ok:      #3FB950;   /* estado ok / sucesso */
    --danger:  #DA3633;   /* botão de perigo */
    --error:   #F85149;   /* texto de erro */
    --warn:    #D29922;   /* estado de alerta */
}

/* ── Base ─────────────────────────────────────────────────────────────── */
.mono       { }
.screen     { width: fill; height: fill; background: var(--bg); }

/* ── Sidebar / top bar ────────────────────────────────────────────────── */
/* .nav_item (era o botão-texto puro do item de sidebar, sem ícone) ficou sem
   uso quando nav_item.gv passou a montar ícone+rótulo numa <row> própria
   (.nav_row_on/.nav_row_off, ali definidas) — Settings/Support também viraram
   NavItem. Mantido comentado, não removido (é reutilizável). */
/* .nav_item       { width: fill; color: var(--surface); padding: 11 14; } */
.tab        { color: var(--surface); padding: 9 16; border-radius: 5 }

/* ── Buttons ──────────────────────────────────────────────────────────── */
.btn_primary      { color: var(--green); padding: 11 20; border-radius: 5 }
.btn_danger       { color: var(--danger); padding: 11 20; border-radius: 5 }
.btn_ghost        { color: var(--border); padding: 11 18; border-radius: 5 }

/* ── Panels & cards ───────────────────────────────────────────────────── */
.content    { width: fill; height: fill; padding: 28 32; spacing: 22; background: var(--bg); }
.panel      { background: var(--surface); border-radius: 7; border-width: 1; border-color: var(--border); padding: 4; }
.card       { width: fill; background: var(--raised); border-radius: 6; border-width: 1; border-color: var(--border); padding: 18; spacing: 10; }

/* ── Typography ───────────────────────────────────────────────────────── */
.title      { size: 30; bold: true; color: var(--text); }
.subtitle   { size: 13; color: var(--muted); }
.muted      { size: 12; color: var(--muted); }
.label_cap  { size: 11; bold: true; color: var(--faint); }

/* ── Shell layout (composição, sem atributos inline no XML) ───────────── */
.header_row   { width: fill; align-y: start; }
.header_titles{ width: fill; spacing: 6; }
.stats_row    { spacing: 14; }
.scroll_fill  { width: fill; height: fill; }
.table_body   { width: fill; }
.row_wrap     { width: fill; }

/* ── Table ────────────────────────────────────────────────────────────── */
.thead      { width: fill; padding: 14 18; background: var(--raised); border-radius: 5; spacing: 0; }
.th         { size: 11; bold: true; color: var(--faint); }
.trow       { width: fill; padding: 13 18; spacing: 0; align-y: center; }
.td         { size: 13; color: var(--text-2); }
.td_key     { size: 13; bold: true; color: var(--accent); }
.col_svc    { width: 240; }
.col_proj   { width: 180; }
.col_state  { width: 170; }
.col_dur    { width: 150; }
.col_start  { width: fill; }
/* Coluna IMAGEM da sub-aba Containers (Docker): mais larga que col_proj porque
   uma referência de imagem (registry/repo:tag ou sha256:<digest>) é tipicamente
   mais longa que "projeto/serviço" — e, sem espaços, não quebra linha (ver
   fmt.docker_containers, que trunca com Util.ellipsis para nunca estourar). */
.col_img    { width: 340; }
.panel_fill { width: fill; height: fill; background: var(--surface); border-radius: 7; border-width: 1; border-color: var(--border); padding: 4; }
.form_panel { width: fill; max-width: 640; background: var(--surface); border-radius: 7; border-width: 1; border-color: var(--border); padding: 24; spacing: 10; }
/* Ponto colorido do StateCell/rp-badge — compartilhado; o rótulo e a paleta
   (state_<kind>) moram no <style> do state_cell.gv. */
.state_dot  { size: 11; }

/* ── Projects / service grid ──────────────────────────────────────────── */
.card_filler   { width: fill; }
.card_head     { width: fill; align-y: center; }
.card_name     { width: fill; size: 16; bold: true; color: var(--text); }
.badge         { spacing: 7; align-y: center; }
.badge_lbl     { size: 12; bold: true; }
.card_open     { width: fill; color: var(--border); padding: 9 14; text-align: center; border-radius: 5 }
.card_edit     { width: fill; color: var(--border); padding: 9 10; text-align: center; border-radius: 5 }
.card_remove   { width: fill; color: var(--danger); padding: 9 10; text-align: center; border-radius: 5 }

/* ── Service detail (compartilhado) ───────────────────────────────────── */
.tabs          { width: fill; spacing: 4; }
.svc_panels    { width: fill; spacing: 14; }
.panel_pad     { width: fill; background: var(--surface); border-radius: 6; border-width: 1; border-color: var(--border); padding: 18; spacing: 8; }
.kv_list       { width: fill; background: var(--surface); border-radius: 6; border-width: 1; border-color: var(--border); padding: 8 18; spacing: 0; }
.kv_row        { width: fill; padding: 12 0; align-y: center; }
/* Linha agarrada durante o drag-and-drop (flag {var}.__dragging do
   glacier-ui): fundo elevado + borda de destaque enquanto o resto reflui. */
.kv_row_drag   { width: fill; padding: 12 10; align-y: center; background: var(--raised); border-radius: 4; border-width: 1; border-color: var(--accent); }
.kv_val_fill   { size: 13; bold: true; color: var(--text-2); }
.env_wrap      { width: fill; height: fill; spacing: 10; }
.env_head      { width: fill; align-y: center; }
.muted_fill    { width: fill; size: 12; color: var(--muted); }
.env_add       { width: fill; spacing: 8; align-y: center; }
.env_in_key    { width: fill; padding: 9 12; }
.env_in_val    { width: fill; padding: 9 12; }
.env_drag_handle { color: var(--faint); padding: 0 6 0 0; cursor: grab; }
.env_dragging    { cursor: grabbing; }
.env_del       { color: var(--danger); padding: 4 10; }
/* Respiro entre o botão ✕ e a chave da variável (evita que o vermelho encoste
   no texto). Usado nas linhas de env de serviço e de projeto. */
.env_sep       { width: 10; }
.env_key       { size: 13; bold: true; color: var(--accent); width: 400; }
.env_list_scroll { width: fill; height: fill; }
/* Editor .env (textarea + toggle), compartilhado por service.gv e shell.gv. */
.env_editor    { width: fill; height: 200; padding: 10 12; font: mono; }
.btn_export    { color: var(--border); padding: 11 22; border-radius: 5; }
.btn_export_on { color: var(--blue); padding: 11 22; border-radius: 5; }
.copy_btn      { color: var(--border); padding: 5 12; border-radius: 4 }
/* Webhook (aba Deployments): a URL ocupa a linha inteira — é longa demais para
   dividir espaço com os botões, que ficam na linha de baixo. */
.wh_block      { width: fill; spacing: 10; }
.wh_url        { width: fill; size: 13; bold: true; color: var(--text-2); font: mono; }
.wh_actions    { spacing: 8; align-y: center; }
.hc_grid       { width: fill; spacing: 14; }
.hc_field      { width: fill; spacing: 6; }

/* ── Forms ────────────────────────────────────────────────────────────── */
.field_input  { width: fill; padding: 13 14; }

/* ── Status badge text color (compartilhado; ok/warn moram nos templates) ─ */
.err   { color: var(--error); }

/* ── Responsivo (glacier-ui 0.9.0+) ────────────────────────────────────────
   O motor só ajusta PROPRIEDADES (não reestrutura Row↔Column nem esconde), então
   "mobile" aqui = modo compacto: menos padding, colunas/fontes menores conforme a
   largura da janela encolhe. A sidebar/topbar têm os deles no <style> do shell. */

/* StatCards ao lado do título (header_row): o Row não quebra linha nem clipa,
   então com muitos cards eles invadem o título bem antes dos 560 que escondem
   .stats_row abaixo. Cada view marca a sua stats_row com a classe do ponto em
   que ela deixa de caber, medido pela densidade: xl = 5 cards com valor largo
   (Deploy Engine, ~1240px de janela com sidebar cheia), lg = 2 cards largos
   (Deployments: STATUS + UPTIME "1d 11h 49m", ~950px), md = 4 cards compactos
   (Docker/Monitoring/Schedules, ~700px com sidebar colapsada). Ingress (2
   cards curtos) cabe até os 560 gerais e fica só com .stats_row. */
@media (max-width: 1280) {
  .stats_hide_xl { hidden: true; }
}

/* Ações da tela de serviço (Deploy/Reload/Rebuild/Stop). Dois arranjos que se
   alternam por largura:
     • >1240px  → `svc_actions_full`: rótulos por extenso, À DIREITA do título
                  (mesma linha — há espaço de sobra).
     • ≤1240px  → `svc_actions_compact`: ícones + tooltip, EMPILHADOS abaixo do
                  título/status (dentro da coluna header_titles, ver service.gv).
   O empilhamento (em vez de encolher na mesma linha) é o que garante que os
   botões nunca dividam linha com o nome quando aperta — antes eles transbordavam
   por cima de "Landing page"/"Running". Base: full visível, compacta oculta; o
   @media inverte as duas. O limiar é medido na largura da JANELA, mas o header
   vive dentro do shell com a sidebar comendo espaço horizontal — 1240px dá a
   folga para os rótulos por extenso só aparecerem quando realmente cabem. */
.svc_actions_full    { hidden: false; }
.svc_actions_compact { hidden: true; }
@media (max-width: 1240) {
  .svc_actions_full    { hidden: true; }
  .svc_actions_compact { hidden: false; }
}

@media (max-width: 1000) {
  .stats_hide_lg { hidden: true; }
}

@media (max-width: 760) {
  .stats_hide_md { hidden: true; }
}

@media (max-width: 900) {
  .content    { padding: 16 18; spacing: 16; }
  .title      { size: 24; }
  .stats_row  { spacing: 10; }
  .thead      { padding: 10 12; }
  .trow       { padding: 10 12; }
  .col_svc    { width: 150; }
  .col_proj   { width: 120; }
  .col_state  { width: 130; }
  .col_dur    { width: 90; }
  .col_img    { width: 220; }
  .form_panel { padding: 16; }
  .grid       { spacing: 10; }
  .card_row   { spacing: 10; }
  .kv_list    { padding: 6 12; }
}

@media (max-width: 560) {
  .content    { padding: 10 10; spacing: 12; }
  .title      { size: 20; }
  .col_svc    { width: 110; }
  .col_proj   { width: 82; }
  .col_state  { width: 110; }
  .col_dur    { width: 64; }
  .col_img    { width: 140; }
  .form_panel { padding: 12; }
  /* Em telas estreitas não há largura pra os cards de stat ao lado do título
     (empilhavam sobre o texto) nem pra a coluna INÍCIO — some com ambos
     (glacier-ui 0.10.0: `hidden`). */
  .stats_row  { hidden: true; }
  .col_start  { hidden: true; }
}
