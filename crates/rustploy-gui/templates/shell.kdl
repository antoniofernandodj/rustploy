import "ServiceDetail"    from="crates/rustploy-gui/templates/service.kdl"
import "HomeViews"        from="crates/rustploy-gui/templates/home.kdl"
import "NewServiceWizard" from="crates/rustploy-gui/templates/new_service.kdl"
import "ProjectCard"      from="crates/rustploy-gui/templates/components/project_card.kdl"
import "ServiceCard"      from="crates/rustploy-gui/templates/components/service_card.kdl"
import "StatCard"         from="crates/rustploy-gui/templates/components/stat_card.kdl"
import "StateCell"        from="crates/rustploy-gui/templates/components/state_cell.kdl"
import "Badge"            from="crates/rustploy-gui/templates/components/badge.kdl"
import "NavItem"          from="crates/rustploy-gui/templates/components/nav_item.kdl"
import "TabButton"        from="crates/rustploy-gui/templates/components/tab_button.kdl"
import "LoadingRow"       from="crates/rustploy-gui/templates/components/loading_row.kdl"
import "PickerRow"        from="crates/rustploy-gui/templates/components/picker_row.kdl"
import "TemplateRow"      from="crates/rustploy-gui/templates/components/template_row.kdl"

Row class="screen" {

  // ── Sidebar ────────────────────────────────────────────────────────
  Column class="sidebar" {
    Column class="brand_box" {
      Text "Rustploy" class="brand"
      Text "PRODUCTION CLUSTER" class="brand_sub"
    }

    Text "DEPLOYMENT OPS" class="nav_section"

    NavItem label="  Deployments" target="deployments" action="nav_deployments"
    NavItem label="  Monitoring" target="monitoring" action="nav_monitoring"
    NavItem label="  Schedules" target="schedules" action="nav_schedules"
    NavItem label="  Ingress" target="ingress" action="nav_ingress"
    NavItem label="  Docker" target="docker" action="nav_docker"

    Text "MANAGEMENT" class="nav_section"

    NavItem label="  Projects ({projects_count})" target="projects" action="nav_projects"

    Column class="nav_spacer"

    Rule

    Button "  Settings" class="nav_item" onClick="nav_settings"
    Button "  Support" class="nav_item" onClick="nav_support"
  }

  // ── Main column ────────────────────────────────────────────────────
  Column class="main_col" {

    // Top bar
    Row class="topbar" {
      TextInput "Search deployments, nodes…"
        class="search"
        value="search"
        onChange="search_changed"
      Text "● rwp · daemon v{daemon_version}" class="muted"
      Button "Stop All" class="btn_danger" onClick="stop_all"
      Button "Disconnect" class="btn_ghost" onClick="disconnect"
    }

    Rule

    // Content
    if cond="{view}" equals="deployments" {
      Column class="content" {
        Row class="header_row" {
          Column class="header_titles" {
            Text "Deployments" class="title"
            Text "Real-time status of services in the cluster." class="subtitle"
          }
          Row class="stats_row" {
            StatCard label="STATUS" value="{services_label}" accent="1"
            StatCard label="UPTIME" value="{daemon_uptime}"
          }
        }

        Column class="panel_fill" {
          Row class="thead" {
            Text "SERVIÇO" class="th col_svc"
            Text "PROJETO" class="th col_proj"
            Text "ESTADO" class="th col_state"
            Text "DURAÇÃO" class="th col_dur"
            Text "INÍCIO" class="th col_start"
          }
          if cond="{data_loading}" equals="true" {
            LoadingRow
          }
          Scrollable if="{data_loading}" not_equals="true" direction=vertical class="scroll_fill" {
            Column class="table_body" {
              Column class="row_wrap" for-each="deployments" var="d" {
                Row class="trow" {
                  Text "{d.service}" class="td_key col_svc"
                  Text "{d.project}" class="td col_proj"
                  StateCell color="{d.state_color}" label="{d.state_label}"
                  Text "{d.duration}" class="td col_dur"
                  Text "{d.start}" class="muted col_start"
                }
                Rule
              }
            }
          }
        }
      }
    }
    else {
      // ── Projects (lista de projetos) ──────────────────────────────
      if cond="{view}" equals="projects" {
        Column class="content" {
          Row class="header_row" {
            Column class="header_titles" {
              Text "Projects" class="title"
              Text "Projetos do cluster e a contagem de serviços de cada um."
                class="subtitle"
            }
            Row class="stats_row" {
              StatCard label="SERVICES" value="{services_count}"
              StatCard label="PROJECTS" value="{projects_count}" accent="1"
            }
          }

          Form name="new_project" onSubmit="create_project" width="fill" {
            Row class="env_add" {
              TextInput "Nome do projeto"
                class="env_in_key"
                formControl="new_proj_name"
                value="new_proj_name"
                onChange="field:new_proj_name"
              TextInput "Descrição (opcional)"
                class="env_in_val"
                formControl="new_proj_desc"
                value="new_proj_desc"
                onChange="field:new_proj_desc"
              Button "Criar projeto" class="btn_primary" onClick="create_project"
            }
          }
          Text "{erro_new_proj_name}" if="{erro_new_proj_name}" notEquals="" class="err"
          Text "{new_proj_msg}" class="muted" if="{new_proj_msg}" not_equals=""

          if cond="{data_loading}" equals="true" {
            LoadingRow
          }
          Scrollable if="{data_loading}" not_equals="true" direction=vertical class="scroll_fill" {
            Column class="grid" {
              Row class="card_row" for-each="project_rows" var="r" {
                ProjectCard for-each="r.cards" var="c"
                  id="{c.id}"
                  filler="{c.filler}"
                  name="{c.name}"
                  service_count="{c.service_count}"
                  running_count="{c.running_count}"
                  description="{c.description}"
                  can_delete="{c.can_delete}"
              }
            }
          }
        }
      }

      else {
        // ── Projeto: serviços de um projeto ──────────────────────────
        if cond="{view}" equals="project_services" {
          Column class="content" {
            Row class="header_row" {
              Column class="header_titles" {
                Button "‹ Projetos" class="btn_ghost" onClick="nav_projects"

                if cond="{editing_project}" equals="true" {
                  Form name="edit_project" onSubmit="save_project_edit" spacing=6 width="fill" {
                    TextInput "Nome do projeto"
                      class="field_input"
                      formControl="edit_proj_name"
                    Text "{erro_edit_proj_name}" if="{erro_edit_proj_name}" notEquals="" class="err"
                    TextInput "Descrição (opcional)"
                      class="field_input"
                      formControl="edit_proj_desc"
                    Row class="env_add" {
                      Button "Salvar" class="btn_primary" onClick="save_project_edit"
                      Button "Cancelar" class="btn_ghost" onClick="cancel_project_edit"
                      Text "{proj_action_msg}" class="muted"
                    }
                  }
                }

                else {
                  Text "{proj_name}" class="title"
                  Text "{proj_description}" class="subtitle"
                  Row class="env_add" {
                    Button "+ Novo serviço" class="btn_primary" onClick="new_service_open"
                    Button "Editar projeto" class="btn_ghost" onClick="edit_project_toggle"
                    Button "Remover projeto"
                      if="{proj_can_delete}"
                      equals="1"
                      class="btn_danger"
                      onClick="delete_project:{selected_project_id}"
                    Text "{proj_action_msg}" class="muted"
                  }
                }
              }
            }

            // Sub-abas do projeto: os cards de serviços e as env vars de
            // nível de projeto (herdadas por todos os serviços no deploy).
            Row class="tabs" {
              TabButton label="Serviços" current="{proj_tab}" target="services" action="proj_tab:services"
              TabButton label="Variáveis ({proj_env_count})" current="{proj_tab}" target="env" action="proj_tab:env"
            }
            Rule

            if cond="{proj_loading}" equals="true" {
              LoadingRow
            }

            if cond="{proj_tab}" equals="env" {
              // ── Variáveis de ambiente do projeto ──────────────────────
              Column class="env_wrap" if="{proj_loading}" not_equals="true" {
                Text "Herdadas por todos os serviços deste projeto no deploy — as do serviço têm precedência."
                  class="muted"
                Form name="penv_add" onSubmit="penv_add" width="fill" {
                  Row class="env_add" {
                    TextInput "KEY"
                      class="env_in_key"
                      formControl="penv_new_key"

                    TextInput "value"
                      class="env_in_val"
                      formControl="penv_new_val"

                    Button "Adicionar"
                      class="btn_primary"
                      onClick="penv_add"
                  }
                }
                Text "{erro_penv_new_key}" if="{erro_penv_new_key}" notEquals="" class="err"
                Scrollable direction=vertical class="env_list_scroll" {
                  Column class="kv_list" {
                    ForEach items="proj_env" var="e" onReorder="penv_reorder" reorderKey="key" {
                      // Linha agarrada muda para kv_row_drag ({e.__dragging}
                      // vem do glacier-ui durante o arrasto).
                      Row class="kv_row_drag" if="{e.__dragging}" equals="true" {
                        Text "⋮ " class="env_drag_handle" dragHandle="true" cursor="grabbing"
                        Button "✕" class="env_del" onClick="penv_del:{e.key}"
                        Text " "
                        Text "{e.key}" class="env_key"
                        Text "{e.value}" class="kv_val_fill"
                      }
                      Row class="kv_row" else {
                        Text "⋮ " class="env_drag_handle" dragHandle="true" cursor="grab"
                        Button "✕" class="env_del" onClick="penv_del:{e.key}"
                        Text " "
                        Text "{e.key}" class="env_key"
                        Text "{e.value}" class="kv_val_fill"
                      }
                    }
                  }
                }
              }
            }

            else {
              Scrollable if="{proj_loading}" not_equals="true" direction=vertical class="scroll_fill" {
                Column class="grid" {
                  Row class="card_row" for-each="project_services" var="r" {
                    ServiceCard for-each="r.cards" var="c"
                      id="{c.id}"
                      filler="{c.filler}"
                      name="{c.name}"
                      port="{c.port}"
                      status_color="{c.status_color}"
                      status_label="{c.status_label}"
                      cpu="{c.cpu}"
                      mem="{c.mem}"
                  }
                }
              }
            }
          }
        }

        else {
          // ── Service detail / wizard de novo serviço / demais views ─
          if cond="{view}" equals="service" {
            ServiceDetail
          }

          else {
            if cond="{view}" equals="new_service" {
              NewServiceWizard
            }

            else {
              HomeViews
            }
          }
        }
      }
    }
  }
}
