<Column class="content">

    <!-- ── Monitoring ───────────────────────────────────────────────────── -->
    <!-- Bloco com múltiplos filhos condicionais: precisa da TAG <if>, não do -->
    <!-- atributo if= (que só condiciona o próprio elemento). -->
    <if cond="{view}" equals="monitoring">
        <Row class="header_row">
            <Column class="header_titles">
                <Text class="title" content="Monitoring" />
                <Text class="subtitle" content="Host and per-container resource usage." />
            </Column>
        </Row>
        <Row class="stats_row">
            <Column class="stat_card"><Text class="label_cap" content="CPU" /><Text class="stat_num" content="{sys_cpu}" /></Column>
            <Column class="stat_card"><Text class="label_cap" content="MEMORY" /><Text class="stat_num_g" content="{sys_mem}" /></Column>
            <Column class="stat_card"><Text class="label_cap" content="DISK" /><Text class="stat_num" content="{sys_disk}" /></Column>
            <Column class="stat_card"><Text class="label_cap" content="LOAD" /><Text class="stat_num" content="{sys_load}" /></Column>
        </Row>
        <Column class="panel_fill">
            <Row class="thead">
                <Text class="th col_svc" content="CONTAINER" />
                <Text class="th col_proj" content="PROJETO" />
                <Text class="th col_dur" content="CPU" />
                <Text class="th col_dur" content="MEM" />
                <Text class="th col_dur" content="RX" />
                <Text class="th col_start" content="TX" />
            </Row>
            <Scrollable direction="vertical" class="scroll_fill">
                <Column class="table_body">
                    <ForEach items="monitoring" var="m">
                        <Column class="row_wrap">
                            <Row class="trow">
                                <Text class="td_key col_svc" content="{m.name}" />
                                <Text class="td col_proj" content="{m.project}" />
                                <Text class="td col_dur" content="{m.cpu}" />
                                <Text class="td col_dur" content="{m.mem}" />
                                <Text class="muted col_dur" content="{m.rx}" />
                                <Text class="muted col_start" content="{m.tx}" />
                            </Row>
                            <Rule />
                        </Column>
                    </ForEach>
                </Column>
            </Scrollable>
        </Column>
    </if>

    <!-- ── Ingress ──────────────────────────────────────────────────────── -->
    <if cond="{view}" equals="ingress">
        <Row class="header_row">
            <Column class="header_titles">
                <Text class="title" content="Ingress" />
                <Text class="subtitle" content="Active routes in the reverse proxy." />
            </Column>
            <Row class="stats_row">
                <Column class="stat_card"><Text class="label_cap" content="ROUTES" /><Text class="stat_num" content="{ingress_count}" /></Column>
            </Row>
        </Row>
        <Column class="panel_fill">
            <Row class="thead">
                <Text class="th col_svc" content="DOMÍNIO" />
                <Text class="th col_proj" content="SERVIÇO" />
                <Text class="th col_dur" content="UPSTREAM" />
                <Text class="th col_start" content="TLS" />
            </Row>
            <Scrollable direction="vertical" class="scroll_fill">
                <Column class="table_body">
                    <ForEach items="ingress" var="i">
                        <Column class="row_wrap">
                            <Row class="trow">
                                <Text class="td_key col_svc" content="{i.domain}" />
                                <Text class="td col_proj" content="{i.service}" />
                                <Text class="td col_dur" content="{i.upstream}" />
                                <Text class="muted col_start" content="{i.tls}" />
                            </Row>
                            <Rule />
                        </Column>
                    </ForEach>
                </Column>
            </Scrollable>
        </Column>
    </if>

    <!-- ── Docker ───────────────────────────────────────────────────────── -->
    <if cond="{view}" equals="docker">
        <Row class="header_row">
            <Column class="header_titles">
                <Text class="title" content="Docker" />
                <Text class="subtitle" content="Containers managed by Rustploy." />
            </Column>
        </Row>
        <Column class="panel_fill">
            <Row class="thead">
                <Text class="th col_svc" content="SERVIÇO" />
                <Text class="th col_proj" content="IMAGEM" />
                <Text class="th col_state" content="ESTADO" />
                <Text class="th col_start" content="CONTAINER" />
            </Row>
            <Scrollable direction="vertical" class="scroll_fill">
                <Column class="table_body">
                    <ForEach items="docker_rows" var="c">
                        <Column class="row_wrap">
                            <Row class="trow">
                                <Text class="td_key col_svc" content="{c.name}" />
                                <Text class="td col_proj" content="{c.image}" />
                                <Row class="state_cell">
                                    <Text class="state_dot" content="●" color="{c.status_color}" />
                                    <Text class="state_lbl" content="{c.status_label}" color="{c.status_color}" />
                                </Row>
                                <Text class="muted col_start" content="{c.container}" />
                            </Row>
                            <Rule />
                        </Column>
                    </ForEach>
                </Column>
            </Scrollable>
        </Column>
    </if>

    <!-- ── Settings: sub-abas Web Server | Git ──────────────────────────── -->
    <if cond="{view}" equals="settings">
        <Row class="header_row">
            <Column class="header_titles">
                <Text class="title" content="Settings" />
                <Text class="subtitle" content="Daemon web server, HTTPS e contas Git." />
            </Column>
        </Row>
        <Row class="tabs">
            <Button if="{settings_tab}" equals="git" class="tab" text="Web Server" onClick="settings_tab:web" />
            <Button else class="tab_on" text="Web Server" onClick="settings_tab:web" />
            <Button if="{settings_tab}" equals="git" class="tab_on" text="Git" onClick="settings_tab:git" />
            <Button else class="tab" text="Git" onClick="settings_tab:git" />
        </Row>
        <Rule />

        <!-- Web Server (default) -->
        <if cond="{settings_tab}" not_equals="git">
            <Column class="form_panel">
                <Text class="label_cap" content="DOMÍNIO / URL BASE" />
                <TextInput class="field_input" placeholder="https://rustploy.meusite.com" value="ss_domain" onChange="ss_domain_changed" />
                <Text class="muted" content="Base das URLs de webhook dos serviços e do callback OAuth." />
                <Text class="label_cap" content="E-MAIL LET'S ENCRYPT (HTTPS AUTOMÁTICO)" />
                <TextInput class="field_input" placeholder="voce@exemplo.com" value="ss_email" onChange="ss_email_changed" />
                <Text class="muted" content="Certificados TLS emitidos automaticamente. Requer restart do daemon." />
                <Row class="env_add">
                    <Button class="btn_primary" text="Save" onClick="settings_save" />
                    <Text class="muted" content="{settings_msg}" />
                </Row>
            </Column>
        </if>

        <!-- Git: contas conectadas + formulário de conexão -->
        <if cond="{settings_tab}" equals="git">
            <Scrollable direction="vertical" class="scroll_fill">
                <Column class="form_panel">
                    <Text class="label_cap" content="CONTAS CONECTADAS ({gitea_count})" />
                    <Text if="{gitea_count}" equals="0" class="muted" content="Nenhuma conta Gitea conectada ainda." />
                    <Column class="kv_list">
                        <ForEach items="gitea_providers" var="p">
                            <Row class="kv_row">
                                <Column class="header_titles">
                                    <Text class="env_key" content="{p.name}" />
                                    <Text class="muted" content="{p.base_url}  ·  {p.auth_mode}  ·  {p.account}" />
                                </Column>
                                <Button class="btn_danger" text="Remover" onClick="gp_delete:{p.id}" />
                            </Row>
                        </ForEach>
                    </Column>

                    <Rule />
                    <Text class="label_cap" content="CONECTAR CONTA GITEA" />
                    <Text if="{gp_msg}" not_equals="" class="muted" content="{gp_msg}" />

                    <Row class="hc_grid">
                        <Column class="hc_field"><Text class="label_cap" content="NOME" /><TextInput class="field_input" placeholder="Meu Gitea" value="gp_name" onChange="field:gp_name" /></Column>
                        <Column class="hc_field"><Text class="label_cap" content="BASE URL" /><TextInput class="field_input" placeholder="https://gitea.exemplo.com" value="gp_base_url" onChange="field:gp_base_url" /></Column>
                    </Row>

                    <Text class="label_cap" content="MÉTODO" />
                    <Row class="tabs">
                        <Button if="{gp_mode}" equals="pat" class="tab" text="OAuth2" onClick="gp_mode:oauth" />
                        <Button else class="tab_on" text="OAuth2" onClick="gp_mode:oauth" />
                        <Button if="{gp_mode}" equals="pat" class="tab_on" text="Token (PAT)" onClick="gp_mode:pat" />
                        <Button else class="tab" text="Token (PAT)" onClick="gp_mode:pat" />
                    </Row>

                    <!-- OAuth2 -->
                    <if cond="{gp_mode}" not_equals="pat">
                        <Text class="label_cap" content="CLIENT ID" />
                        <TextInput class="field_input" placeholder="" value="gp_client_id" onChange="field:gp_client_id" />
                        <Text class="label_cap" content="CLIENT SECRET" />
                        <TextInput class="field_input" secure="true" placeholder="" value="gp_client_secret" onChange="field:gp_client_secret" />
                        <Text class="label_cap" content="REDIRECT URI (cole no app OAuth do Gitea)" />
                        <Row class="kv_row">
                            <Text class="kv_val_fill" content="{gp_redirect}" />
                            <Button class="copy_btn" text="Copiar" onClick="clipboard:gp_redirect" />
                        </Row>
                        <Text class="muted" content="No Gitea: Settings → Applications → crie um OAuth2 app e cole a Redirect URI acima." />
                    </if>

                    <!-- PAT -->
                    <if cond="{gp_mode}" equals="pat">
                        <Text class="label_cap" content="PERSONAL ACCESS TOKEN" />
                        <TextInput class="field_input" secure="true" placeholder="" value="gp_pat" onChange="field:gp_pat" />
                        <Text class="muted" content="No Gitea: Settings → Applications → Generate New Token (escopo: repo)." />
                    </if>

                    <Row class="env_add">
                        <Button class="btn_primary" text="Conectar" onClick="gp_connect" />
                        <Button class="tab" text="Atualizar lista" onClick="gp_refresh" />
                    </Row>
                </Column>
            </Scrollable>
        </if>
    </if>

    <!-- ── Schedules / Support (placeholders) ───────────────────────────── -->
    <Column class="content_center" if="{view}" equals="schedules">
        <Text class="title" content="Schedules" />
        <Text class="subtitle" content="Agendamentos de auto-deploy — em breve." />
    </Column>
    <Column class="content_center" if="{view}" equals="support">
        <Text class="title" content="Support" />
        <Text class="subtitle" content="github.com/antoniofernandodj/rustploy" />
    </Column>

</Column>
