// Props: title, subtitle, button_label, action
//
// Linha de escolha do wizard "Novo serviço": título + subtítulo à esquerda e um
// botão de ação à direita. Usada nos passos de escolha de tipo, de banco e de
// template.
Row class="kv_row" {
  Column class="header_titles" {
    Text "{title}" class="env_key"
    Text "{subtitle}" class="muted"
  }
  Button "{button_label}" class="btn_primary" onClick="{action}"
}
