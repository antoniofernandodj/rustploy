<Row class="screen">

    <!-- ── Sidebar ────────────────────────────────────────────────────── -->
    <Column class="sidebar">
        <Column class="brand_box">
            <Text class="brand" content="Rustploy Remote" />
            <Text class="brand_sub" content="PRODUCTION CLUSTER" />
        </Column>

        <Text class="nav_section" content="DEPLOYMENT OPS" />

        <Button if="{view}" equals="deployments" class="nav_item_on" text="  Deployments" onClick="nav_deployments" />
        <Button else class="nav_item" text="  Deployments" onClick="nav_deployments" />

        <Button if="{view}" equals="monitoring" class="nav_item_on" text="  Monitoring" onClick="nav_monitoring" />
        <Button else class="nav_item" text="  Monitoring" onClick="nav_monitoring" />

        <Button if="{view}" equals="schedules" class="nav_item_on" text="  Schedules" onClick="nav_schedules" />
        <Button else class="nav_item" text="  Schedules" onClick="nav_schedules" />

        <Button if="{view}" equals="ingress" class="nav_item_on" text="  Ingress" onClick="nav_ingress" />
        <Button else class="nav_item" text="  Ingress" onClick="nav_ingress" />

        <Button if="{view}" equals="docker" class="nav_item_on" text="  Docker" onClick="nav_docker" />
        <Button else class="nav_item" text="  Docker" onClick="nav_docker" />

        <Text class="nav_section" content="MANAGEMENT" />

        <Button if="{view}" equals="projects" class="nav_item_on" text="  Projects ({projects_count})" onClick="nav_projects" />

        <Button else class="nav_item" text="  Projects ({projects_count})" onClick="nav_projects" />
        <Column class="nav_spacer" />

        <Rule />
        <Button class="nav_item" text="  Settings" onClick="nav_settings" />
        <Button class="nav_item" text="  Support" onClick="nav_support" />
    </Column>

    <!-- ── Main column ────────────────────────────────────────────────── -->
    <Column class="main_col">

        <!-- Top bar -->
        <Row class="topbar">
            <TextInput class="search" placeholder="Search deployments, nodes…" value="search" onChange="search_changed" />
            <Text class="muted" content="● rwp · daemon v{daemon_version}" />
            <Button class="btn_primary" text="Deploy" onClick="deploy" />
            <Button class="btn_danger" text="Stop All" onClick="stop_all" />
            <Button class="btn_ghost" text="Disconnect" onClick="disconnect" />
        </Row>

        <Rule />

        <!-- Content -->
        <if cond="{view}" equals="deployments">
            <Column class="content">
                <Row class="header_row">
                    <Column class="header_titles">
                        <Text class="title" content="Deployments" />
                        <Text class="subtitle" content="Real-time status of services in the cluster." />
                    </Column>
                    <Row class="stats_row">
                        <Column class="stat_card">
                            <Text class="label_cap" content="STATUS" />
                            <Text class="stat_num_g" content="{services_label}" />
                        </Column>
                        <Column class="stat_card">
                            <Text class="label_cap" content="UPTIME" />
                            <Text class="stat_num" content="{daemon_uptime}" />
                        </Column>
                    </Row>
                </Row>

                <Column class="panel_fill">
                    <Row class="thead">
                        <Text class="th col_svc" content="SERVIÇO" />
                        <Text class="th col_proj" content="PROJETO" />
                        <Text class="th col_state" content="ESTADO" />
                        <Text class="th col_dur" content="DURAÇÃO" />
                        <Text class="th col_start" content="INÍCIO" />
                    </Row>
                    <Scrollable direction="vertical" class="scroll_fill">
                        <Column class="table_body">
                            <ForEach items="deployments" var="d">
                                <Column class="row_wrap">
                                    <Row class="trow">
                                        <Text class="td_key col_svc" content="{d.service}" />
                                        <Text class="td col_proj" content="{d.project}" />
                                        <Row class="state_cell">
                                            <Text class="state_dot" content="●" color="{d.state_color}" />
                                            <Text class="state_lbl" content="{d.state_label}" color="{d.state_color}" />
                                        </Row>
                                        <Text class="td col_dur" content="{d.duration}" />
                                        <Text class="muted col_start" content="{d.start}" />
                                    </Row>
                                    <Rule />
                                </Column>
                            </ForEach>
                        </Column>
                    </Scrollable>
                </Column>
            </Column>
        </if>
        <else>
            <!-- ── Projects (grid de cards de serviço) ──────────────────── -->
            <if cond="{view}" equals="projects">
                <Column class="content">
                    <Row class="header_row">
                        <Column class="header_titles">
                            <Text class="title" content="Projects" />
                            <Text class="subtitle" content="Services across every project, with live resource usage." />
                        </Column>
                        <Row class="stats_row">
                            <Column class="stat_card">
                                <Text class="label_cap" content="SERVICES" />
                                <Text class="stat_num" content="{services_count}" />
                            </Column>
                            <Column class="stat_card">
                                <Text class="label_cap" content="PROJECTS" />
                                <Text class="stat_num_g" content="{projects_count}" />
                            </Column>
                        </Row>
                    </Row>

                    <Scrollable direction="vertical" class="scroll_fill">
                        <Column class="grid">
                            <Row for-each="service_rows" var="r" class="card_row">
                                <ForEach items="r.cards" var="c">
                                    <Column if="{c.filler}" equals="1" class="card_filler" />

                                    <Column else class="card">
                                        <Row class="card_head">
                                            <Text class="card_name" content="{c.name}" />
                                            <Row class="badge">
                                                <Text class="state_dot" content="●" color="{c.status_color}" />
                                                <Text class="badge_lbl" content="{c.status_label}" color="{c.status_color}" />
                                            </Row>
                                        </Row>
                                        <Text class="muted" content="{c.project} · :{c.port}" />
                                        <Rule />
                                        <Row class="card_stats">
                                            <Column class="card_stat">
                                                <Text class="label_cap" content="CPU" />
                                                <Text class="card_stat_num" content="{c.cpu}" />
                                            </Column>
                                            <Column class="card_stat">
                                                <Text class="label_cap" content="MEM" />
                                                <Text class="card_stat_num" content="{c.mem}" />
                                            </Column>
                                        </Row>
                                        <Button class="card_open" text="Open  ›" onClick="open_service:{c.id}" />
                                    </Column>
                                </ForEach>
                            </Row>
                        </Column>
                    </Scrollable>
                </Column>
            </if>
            <else>
                <!-- ── Service detail (img 4) ───────────────────────────── -->
                <ServiceDetail if="{view}" equals="service" />
                <HomeViews else />
            </else>
        </else>
    </Column>
</Row>

<import name="ServiceDetail" from="crates/remote-ui/templates/service.xml" />
<import name="HomeViews" from="crates/remote-ui/templates/home.xml" />
