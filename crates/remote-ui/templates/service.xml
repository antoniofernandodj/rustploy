<Column class="content">

    <!-- ── Header: nome + estado + ações ────────────────────────────────── -->
    <Row class="svc_head">
        <Column class="header_titles">
            <Row class="svc_title_row">
                <Button class="btn_ghost" text="‹ Projects" onClick="nav_projects" />
                <Text class="title" content="{svc_name}" />
                <Row class="badge">
                    <Text class="state_dot" content="●" color="{svc_status_color}" />
                    <Text class="badge_lbl" content="{svc_status_label}" color="{svc_status_color}" />
                </Row>
            </Row>
            <Text class="subtitle" content="{svc_project}  ·  {svc_source_kind}" />
            <if cond="{svc_action_msg}" not_equals="">
                <Text class="muted" content="{svc_action_msg}" />
            </if>
        </Column>
        <Row class="svc_actions">
            <Button class="btn_primary" text="Deploy" onClick="svc_deploy" />
            <Button class="btn_blue" text="Reload" onClick="svc_reload" />
            <Button class="btn_blue" text="Rebuild" onClick="svc_rebuild" />
            <Button class="btn_danger" text="Stop" onClick="svc_stop" />
        </Row>
    </Row>

    <!-- ── Abas ─────────────────────────────────────────────────────────── -->
    <Row class="tabs">
        <if cond="{tab}" equals="general"><Button class="tab_on" text="General" onClick="tab:general" /></if>
        <else><Button class="tab" text="General" onClick="tab:general" /></else>
        <if cond="{tab}" equals="connection"><Button class="tab_on" text="Connection" onClick="tab:connection" /></if>
        <else><Button class="tab" text="Connection" onClick="tab:connection" /></else>
        <if cond="{tab}" equals="environment"><Button class="tab_on" text="Environment" onClick="tab:environment" /></if>
        <else><Button class="tab" text="Environment" onClick="tab:environment" /></else>
        <if cond="{tab}" equals="domains"><Button class="tab_on" text="Domains" onClick="tab:domains" /></if>
        <else><Button class="tab" text="Domains" onClick="tab:domains" /></else>
        <if cond="{tab}" equals="deployments"><Button class="tab_on" text="Deployments" onClick="tab:deployments" /></if>
        <else><Button class="tab" text="Deployments" onClick="tab:deployments" /></else>
        <if cond="{tab}" equals="healthcheck"><Button class="tab_on" text="Healthcheck" onClick="tab:healthcheck" /></if>
        <else><Button class="tab" text="Healthcheck" onClick="tab:healthcheck" /></else>
        <if cond="{tab}" equals="logs"><Button class="tab_on" text="Logs" onClick="tab:logs" /></if>
        <else><Button class="tab" text="Logs" onClick="tab:logs" /></else>
        <if cond="{tab}" equals="advanced"><Button class="tab_on" text="Advanced" onClick="tab:advanced" /></if>
        <else><Button class="tab" text="Advanced" onClick="tab:advanced" /></else>
    </Row>

    <Rule />

    <!-- ── Corpo: conteúdo da aba + painel lateral ──────────────────────── -->
    <Row class="svc_body">

        <Column class="svc_main">
            <if cond="{svc_error}" not_equals="">
                <Text class="svc_err" content="{svc_error}" />
            </if>

            <!-- General -->
            <if cond="{tab}" equals="general">
                <Column class="svc_panels">
                    <Column class="panel_pad">
                        <Text class="label_cap" content="SOURCE PROVIDER" />
                        <Text class="kv_val" content="{svc_source_kind}" />
                        <Text class="muted" content="{svc_source_detail}" />
                    </Column>
                    <Column class="panel_pad">
                        <Text class="label_cap" content="BUILD ENGINE" />
                        <Text class="kv_val" content="{svc_build}" />
                    </Column>
                    <Column class="panel_pad">
                        <Text class="label_cap" content="REPLICAS" />
                        <Text class="kv_val" content="{svc_replicas}" />
                    </Column>
                </Column>
            </if>

            <!-- Connection -->
            <if cond="{tab}" equals="connection">
                <Column class="kv_list">
                    <Row class="kv_row"><Text class="kv_key" content="Container port" /><Text class="kv_val_fill" content="{svc_port}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="Host port" /><Text class="kv_val_fill" content="{svc_host_port}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="Domain" /><Text class="kv_val_fill" content="{svc_domain}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="TLS" /><Text class="kv_val_fill" content="{svc_tls}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="Database" /><Text class="kv_val_fill" content="{svc_db_kind}" /></Row>
                </Column>
            </if>

            <!-- Environment -->
            <if cond="{tab}" equals="environment">
                <Column class="env_wrap">
                    <Row class="env_head">
                        <Text class="muted_fill" content="{svc_env_count} variável(eis)" />
                        <Button class="tab" text="Exportar .env" onClick="env_export" />
                    </Row>
                    <Row class="env_add">
                        <TextInput class="env_in_key" placeholder="KEY" value="env_new_key" onChange="env_new_key_changed" />
                        <TextInput class="env_in_val" placeholder="value" value="env_new_val" onChange="env_new_val_changed" />
                        <Button class="btn_primary" text="Adicionar" onClick="env_add" />
                    </Row>
                    <Scrollable direction="vertical" class="scroll_fill">
                        <Column class="kv_list">
                            <ForEach items="svc_env" var="e">
                                <Row class="kv_row">
                                    <Button class="env_del" text="✕" onClick="env_del:{e.key}" />
                                    <Text class="env_key" content="{e.key}" />
                                    <Text class="kv_val_fill" content="{e.value}" />
                                </Row>
                            </ForEach>
                        </Column>
                    </Scrollable>
                </Column>
            </if>

            <!-- Domains -->
            <if cond="{tab}" equals="domains">
                <Column class="kv_list">
                    <Row class="kv_row"><Text class="kv_key" content="Domain" /><Text class="kv_val_fill" content="{svc_domain}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="Host port" /><Text class="kv_val_fill" content="{svc_host_port}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="TLS" /><Text class="kv_val_fill" content="{svc_tls}" /></Row>
                </Column>
            </if>

            <!-- Deployments -->
            <if cond="{tab}" equals="deployments">
                <Column class="log_panel">
                    <Text class="muted" content="{svc_deployments_count} deployments" />
                    <Scrollable direction="vertical" class="scroll_fill">
                        <Column class="table_body">
                            <ForEach items="svc_deployments" var="d">
                                <Column class="row_wrap">
                                    <Row class="trow">
                                        <Text class="td_key col_dep_id" content="{d.id}" />
                                        <Row class="state_cell">
                                            <Text class="state_dot" content="●" color="{d.state_color}" />
                                            <Text class="state_lbl" content="{d.state_label}" color="{d.state_color}" />
                                        </Row>
                                        <Text class="td col_dur" content="{d.duration}" />
                                        <Text class="muted col_start" content="{d.start}" />
                                    </Row>
                                    <Text class="dep_image" content="{d.image}" />
                                    <Rule />
                                </Column>
                            </ForEach>
                        </Column>
                    </Scrollable>
                </Column>
            </if>

            <!-- Healthcheck -->
            <if cond="{tab}" equals="healthcheck">
                <Column class="panel_pad">
                    <Text class="label_cap" content="HEALTHCHECK" />
                    <Text class="kv_val" content="{svc_hc}" />
                </Column>
            </if>

            <!-- Logs -->
            <if cond="{tab}" equals="logs">
                <Column class="log_panel">
                    <Text class="muted" content="{svc_logs_count} linhas" />
                    <Scrollable direction="vertical" class="scroll_fill">
                        <Column class="log_body">
                            <ForEach items="svc_logs" var="l">
                                <Row class="log_line">
                                    <Text class="log_time" content="{l.time}" />
                                    <Text class="log_text" content="{l.line}" color="{l.color}" />
                                </Row>
                            </ForEach>
                        </Column>
                    </Scrollable>
                </Column>
            </if>

            <!-- Advanced -->
            <if cond="{tab}" equals="advanced">
                <Column class="kv_list">
                    <Row class="kv_row"><Text class="kv_key" content="Replicas" /><Text class="kv_val_fill" content="{svc_replicas}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="Run command" /><Text class="kv_val_fill" content="{svc_run_command}" /></Row>
                    <Row class="kv_row"><Text class="kv_key" content="Run args" /><Text class="kv_val_fill" content="{svc_run_args}" /></Row>
                </Column>
            </if>
        </Column>

        <!-- Painel lateral: status + live output -->
        <Column class="svc_aside">
            <Column class="aside_panel">
                <Text class="label_cap" content="STATUS" />
                <Row class="badge">
                    <Text class="state_dot" content="●" color="{svc_status_color}" />
                    <Text class="badge_lbl" content="{svc_status_label}" color="{svc_status_color}" />
                </Row>
                <Text class="label_cap" content="UPTIME" />
                <Text class="kv_val" content="{daemon_uptime}" />
                <Text class="label_cap" content="SERVICES" />
                <Text class="kv_val" content="{services_label}" />
            </Column>

            <Column class="aside_panel_fill">
                <Text class="label_cap" content="LIVE OUTPUT" />
                <Scrollable direction="vertical" class="scroll_fill">
                    <Column class="log_body">
                        <ForEach items="svc_logs" var="l">
                            <Row class="log_line">
                                <Text class="log_time" content="{l.time}" />
                                <Text class="log_text" content="{l.line}" color="{l.color}" />
                            </Row>
                        </ForEach>
                    </Column>
                </Scrollable>
            </Column>
        </Column>

    </Row>
</Column>
