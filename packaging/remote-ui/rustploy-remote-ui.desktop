[Desktop Entry]
Version=1.0
Type=Application
Name=Rustploy
GenericName=PaaS Dashboard
Comment=Gerencie deploys e serviços no Rustploy
Exec=rustploy-gui
Icon=rustploy-gui
Categories=Development;System;
Keywords=deploy;paas;docker;container;server;
StartupNotify=true
# Must match the Wayland app id / X11 WM_CLASS iced sets from
# PlatformSpecific.application_id ("rustploy-gui") so the compositor maps
# the running window to this entry — that is what gives the dock its icon.
StartupWMClass=rustploy-gui
Terminal=false
